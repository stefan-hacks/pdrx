#!/usr/bin/env bash
# shellcheck disable=SC2034
#
# pdrx - Portable Dynamic Reproducible gnu/linuX
# Pure Bash tool for fully reproducible Linux system setups.
# Imperative install/remove with automatic declarative config sync.
# Supports: apt, dnf, yum, pacman, zypper, brew, flatpak, snap, cargo, winget
#
# Scope (deliberately bounded — see README "Scope" section):
#   IN:  packages, repo/PPA sources, dotfiles, DE settings, enabled systemd units
#   OUT: partitioning, fstab, LUKS, filesystem provisioning — that's cloud-init /
#        Ansible / Nix territory. pdrx declares what's installed and enabled on
#        top of an already-provisioned OS, not the OS itself.
#
# No Nix dependency. Works on Debian, Ubuntu, Fedora, Arch, openSUSE, Windows (winget), etc.

set -euo pipefail

VERSION="1.7.1"

# =============================================================================
# PORTABLE HELPERS
# =============================================================================

get_script_path() {
  local src="${BASH_SOURCE[0]:-$0}"
  local dir
  while true; do
    dir="$(cd "$(dirname "$src")" 2>/dev/null && pwd)"
    [ -n "$dir" ] || dir="$PWD"
    src="$(basename "$src")"
    [ -L "$dir/$src" ] || break
    src="$(readlink "$dir/$src")"
    [[ "$src" == /* ]] || src="$dir/$src"
  done
  echo "$dir/$src"
}

date_iso_seconds() {
  if date -Iseconds >/dev/null 2>&1; then
    date -Iseconds
  else
    date "+%Y-%m-%dT%H:%M:%S%z"
  fi
}

detect_os_id() {
  if [ -f /etc/os-release ]; then
    # shellcheck source=/dev/null
    . /etc/os-release
    echo "${ID:-unknown}"
  else
    echo "unknown"
  fi
}

detect_os_id_like() {
  if [ -f /etc/os-release ]; then
    # shellcheck source=/dev/null
    . /etc/os-release
    echo "${ID_LIKE:-$ID}"
  else
    echo "unknown"
  fi
}

# FIX (1.7.0): escape a string for safe embedding inside a BRE/ERE grep
# pattern. Package names can legally contain '.', '+', '[' etc (e.g.
# "gcc-12", "libssl1.1"); without this, grep patterns built from raw
# package names can match more (or less) than intended, or error out.
regex_escape() {
  printf '%s' "$1" | sed -e 's/[][\\.^$*+?(){}|]/\\&/g'
}

# =============================================================================
# DIRECTORIES
# =============================================================================

PDRX_HOME="${PDRX_HOME:-$HOME/.pdrx}"
PDRX_CONFIG="$PDRX_HOME/config"
PDRX_BACKUP="$PDRX_HOME/backups"
PDRX_STATE="$PDRX_HOME/state"
PACKAGES_CONF="$PDRX_CONFIG/packages.conf"
SOURCES_CONF="$PDRX_CONFIG/sources.conf"
SYSTEMD_CONF="$PDRX_CONFIG/systemd.conf"
DOTFILES_DIR="$PDRX_CONFIG/dotfiles"
TRACKED_DOTFILES="$PDRX_STATE/tracked-dotfiles"
DESKTOP_EXPORT="$PDRX_CONFIG/desktop-export"
GENERATIONS_FILE="$PDRX_STATE/generations"
HOOKS_DIR="$PDRX_CONFIG/hooks"
LOG_FILE="$PDRX_STATE/pdrx.log"

# =============================================================================
# AUDIT LOG
# =============================================================================

# FIX (1.7.0): every state-changing action is appended to a JSON-lines audit
# log so a failed `apply` on a fresh box is diagnosable after the fact, and
# `pdrx history` can correlate with backups. Best-effort: never fails the
# calling command if the log can't be written (e.g. read-only home during
# a container test).
log_action() {
  local action="$1" pm="${2:-}" pkg="${3:-}" result="${4:-}" extra="${5:-}"
  [ -d "$PDRX_STATE" ] || return 0
  local ts
  ts=$(date_iso_seconds)
  printf '{"ts":"%s","action":"%s","pm":"%s","pkg":"%s","result":"%s","extra":"%s"}\n' \
    "$ts" "$action" "$pm" "$pkg" "$result" "$extra" >> "$LOG_FILE" 2>/dev/null || true
}

run_history() {
  require_initialized
  local n="${1:-30}"
  if [ ! -f "$LOG_FILE" ]; then
    log_info "No history yet."
    return 0
  fi
  tail -n "$n" "$LOG_FILE"
}

# =============================================================================
# PACKAGE MANAGER REGISTRY
# =============================================================================

detect_available_pms() {
  local pms=""
  command -v apt-get >/dev/null 2>&1  && pms="$pms apt"
  command -v dnf     >/dev/null 2>&1  && pms="$pms dnf"
  command -v yum     >/dev/null 2>&1  && pms="$pms yum"
  command -v pacman  >/dev/null 2>&1  && pms="$pms pacman"
  command -v zypper  >/dev/null 2>&1  && pms="$pms zypper"
  command -v brew    >/dev/null 2>&1  && pms="$pms brew"
  command -v flatpak >/dev/null 2>&1  && pms="$pms flatpak"
  command -v snap    >/dev/null 2>&1  && pms="$pms snap"
  command -v cargo   >/dev/null 2>&1  && pms="$pms cargo"
  command -v winget  >/dev/null 2>&1  && pms="$pms winget"
  echo "$pms" | sed 's/^ *//;s/ *$//'
}

pm_available() {
  local pm="$1"
  case "$pm" in
    apt)     command -v apt-get >/dev/null 2>&1 ;;
    dnf)     command -v dnf     >/dev/null 2>&1 ;;
    yum)     command -v yum     >/dev/null 2>&1 ;;
    pacman)  command -v pacman  >/dev/null 2>&1 ;;
    zypper)  command -v zypper  >/dev/null 2>&1 ;;
    brew)    command -v brew    >/dev/null 2>&1 ;;
    flatpak) command -v flatpak >/dev/null 2>&1 ;;
    snap)    command -v snap    >/dev/null 2>&1 ;;
    cargo)   command -v cargo   >/dev/null 2>&1 ;;
    winget)  command -v winget  >/dev/null 2>&1 ;;
    *)       return 1 ;;
  esac
}

pm_list_installed() {
  # Returns ONLY user-initiated packages — excludes OS defaults, auto-deps,
  # and packages pulled in as transitive requirements by other tools.
  # Used by `pdrx sync` so the declarative config stays minimal and clean.
  local pm="$1"
  case "$pm" in
    apt)
      apt-mark showmanual 2>/dev/null | sort
      ;;
    dnf)
      if dnf repoquery --userinstalled --qf '%{name}' >/dev/null 2>&1; then
        dnf repoquery --userinstalled --qf '%{name}' 2>/dev/null \
          | grep -v '^$' | sort -u
      else
        dnf history userinstalled 2>/dev/null \
          | awk 'NR>1 {print $1}' | sed 's/\..*//' | sort -u
      fi
      ;;
    yum)
      yum history userinstalled 2>/dev/null \
        | awk 'NR>1 {print $1}' | sed 's/\..*//' | sort -u \
        || yum list installed 2>/dev/null \
             | awk 'NR>1 {print $1}' | sed 's/\..*//' | sort -u
      ;;
    pacman)
      pacman -Qeq 2>/dev/null
      ;;
    zypper)
      zypper -q packages --userinstalled 2>/dev/null \
        | awk -F'|' 'NR>3 {gsub(/^ +| +$/,"",$3); if($3!="" && $3!="Name") print $3}' \
        || zypper -q packages --installed-only 2>/dev/null \
             | awk -F'|' 'NR>3 {gsub(/^ +| +$/,"",$3); if($3!="" && $3!="Name") print $3}'
      ;;
    brew)
      brew leaves --installed-on-request 2>/dev/null
      brew list --cask 2>/dev/null
      ;;
    flatpak)
      flatpak list --app --columns=application 2>/dev/null \
        || flatpak list --app 2>/dev/null | awk '{print $1}'
      ;;
    snap)
      snap list 2>/dev/null \
        | awk 'NR>1 && $1!="core" && $1!="core18" && $1!="core20" \
                    && $1!="core22" && $1!="core24" && $1!="snapd" {print $1}'
      ;;
    cargo)
      cargo install --list 2>/dev/null | grep '^[a-z]' | sed 's/:$//' | awk '{print $1}'
      ;;
    winget)
      winget list --source winget 2>/dev/null | awk 'NR>3 && NF>=1 {print $1}'
      ;;
    *)
      return 1
      ;;
  esac
}

pm_installed_version() {
  local pm="$1"
  local pkg="$2"
  case "$pm" in
    apt)
      dpkg -l "$pkg" 2>/dev/null | awk '/^ii/ {print $3}' | head -1
      ;;
    dnf|yum)
      rpm -q --queryformat '%{VERSION}' "$pkg" 2>/dev/null | head -1
      ;;
    pacman)
      pacman -Q "$pkg" 2>/dev/null | awk '{print $2}'
      ;;
    zypper)
      rpm -q --queryformat '%{VERSION}' "$pkg" 2>/dev/null | head -1
      ;;
    brew)
      brew list --versions "$pkg" 2>/dev/null | awk '{print $2}' | head -1
      ;;
    flatpak)
      flatpak info "$pkg" 2>/dev/null | awk '/Version:/ {print $2}' | head -1
      ;;
    snap)
      snap list "$pkg" 2>/dev/null | awk 'NR>1 {print $2}' | head -1
      ;;
    cargo)
      cargo install --list 2>/dev/null \
        | grep "^${pkg} " | grep -oE '[0-9]+\.[0-9]+\.[0-9]+' | head -1
      ;;
    winget)
      winget list --id "$pkg" 2>/dev/null | awk 'NR>3 {print $3}' | head -1
      ;;
    *)
      echo ""
      ;;
  esac
}

_print_search_header() {
  printf "%-28s %-14s %-18s %-8s %s\n" "Name" "Version" "Publisher" "Notes" "Summary"
  printf "%-28s %-14s %-18s %-8s %s\n" \
    "---------------------------" "-------------" "-----------------" "--------" "--------"
}

pm_search_formatted() {
  local term="$1"
  local pm="$2"
  local name version publisher notes summary
  case "$pm" in
    apt)
      apt-cache search "$term" 2>/dev/null | head -20 | while IFS= read -r line; do
        name="${line%% -*}"
        summary="${line#*- }"
        [ "$name" = "$line" ] && summary="-"
        version=""
        if [ -n "$name" ]; then
          version=$(apt-cache policy "$name" 2>/dev/null | awk '/Candidate:/ {print $2; exit}')
          [ -z "$version" ] && version="-"
        fi
        printf "%-28s %-14s %-18s %-8s %s\n" \
          "$name" "${version:0:14}" "-" "-" "${summary:0:60}"
      done
      ;;
    dnf|yum)
      "$pm" search "$term" 2>/dev/null | awk 'NR>1 && /^[a-zA-Z]/ {print $1}' \
        | head -20 | while IFS= read -r name; do
        [ -z "$name" ] && continue
        version=$("$pm" list available "$name" 2>/dev/null | awk 'NR<=2 {print $2}' | tail -1)
        [ -z "$version" ] && version="-"
        printf "%-28s %-14s %-18s %-8s %s\n" \
          "$name" "${version:0:14}" "-" "-" "-"
      done
      ;;
    pacman)
      pacman -Ss "$term" 2>/dev/null | grep -E '^[a-z]' | head -40 \
        | while IFS= read -r line; do
        name=$(echo "$line" | awk '{print $1}' | sed 's|.*/||')
        version=$(echo "$line" | awk '{print $2}')
        summary="${line#*  }"
        summary="${summary#*  }"
        [ -z "$version" ] && version="-"
        printf "%-28s %-14s %-18s %-8s %s\n" \
          "$name" "${version:0:14}" "-" "-" "${summary:0:60}"
      done
      ;;
    zypper)
      zypper search "$term" 2>/dev/null \
        | awk -F'|' 'NR>2 && $3!="" {gsub(/^ +| +$/,"",$3); gsub(/^ +| +$/,"",$5); print $3"\t"$5}' \
        | head -20 | while IFS= read -r line; do
        name="${line%%$'\t'*}"
        summary="${line#*$'\t'}"
        [ -z "$summary" ] && summary="-"
        printf "%-28s %-14s %-18s %-8s %s\n" \
          "$name" "-" "-" "-" "${summary:0:60}"
      done
      ;;
    brew)
      brew search "$term" 2>/dev/null | head -20 | while IFS= read -r name; do
        [ -z "$name" ] && continue
        version=$(brew info "$name" 2>/dev/null | head -1 | sed 's/^.*: //')
        [ -z "$version" ] && version="-"
        printf "%-28s %-14s %-18s %-8s %s\n" \
          "$name" "${version:0:14}" "-" "-" "-"
      done
      ;;
    flatpak)
      flatpak search "$term" 2>/dev/null | tail -n +2 | head -20 \
        | while IFS= read -r line; do
        name=$(echo "$line" | awk '{print $1}')
        version=$(echo "$line" | awk '{print $2}')
        [ -z "$name" ] && continue
        [ -z "$version" ] && version="-"
        summary=$(echo "$line" | cut -f3-)
        [ -z "$summary" ] && summary="-"
        printf "%-28s %-14s %-18s %-8s %s\n" \
          "$name" "${version:0:14}" "-" "-" "${summary:0:60}"
      done
      ;;
    snap)
      snap search "$term" 2>/dev/null | head -21 | while IFS= read -r line; do
        name=$(echo "$line" | awk '{print $1}')
        version=$(echo "$line" | awk '{print $2}')
        publisher=$(echo "$line" | awk '{print $3}')
        notes=$(echo "$line" | awk '{print $4}')
        summary=$(echo "$line" | cut -f5-)
        [ -z "$name" ] && continue
        [ "$name" = "Name" ] && continue
        [ -z "$version" ] && version="-"
        [ -z "$publisher" ] && publisher="-"
        [ -z "$notes" ] && notes="-"
        [ -z "$summary" ] && summary="-"
        printf "%-28s %-14s %-18s %-8s %s\n" \
          "$name" "${version:0:14}" "${publisher:0:18}" "${notes:0:8}" "${summary:0:60}"
      done
      ;;
    cargo)
      cargo search "$term" 2>/dev/null | head -20 | while IFS= read -r line; do
        name=$(echo "$line" | awk '{print $1}' | tr -d '"')
        summary=$(echo "$line" | cut -d'"' -f2)
        [ -z "$name" ] && continue
        version=$(echo "$line" | grep -oE '[0-9]+\.[0-9]+\.[0-9]+' | head -1)
        [ -z "$version" ] && version="-"
        printf "%-28s %-14s %-18s %-8s %s\n" \
          "$name" "$version" "-" "-" "${summary:0:60}"
      done
      ;;
    winget)
      winget search "$term" 2>/dev/null | awk 'NR>3 && NF>=2 {print $1"\t"$2"\t"$3}' \
        | head -20 | while IFS= read -r line; do
        name=$(echo "$line" | awk -F'\t' '{print $1}')
        version=$(echo "$line" | awk -F'\t' '{print $2}')
        publisher=$(echo "$line" | awk -F'\t' '{print $3}')
        [ -z "$name" ] && continue
        [ -z "$version" ] && version="-"
        [ -z "$publisher" ] && publisher="-"
        printf "%-28s %-14s %-18s %-8s %s\n" \
          "${name:0:28}" "${version:0:14}" "${publisher:0:18}" "-" "-"
      done
      ;;
    *)
      return 1
      ;;
  esac
}

pm_install() {
  local pm="$1"
  local pkg="$2"
  local version="${3:-}"
  case "$pm" in
    apt)
      if [ -n "$version" ]; then
        sudo apt-get install -y "${pkg}=${version}"
      else
        sudo apt-get install -y "$pkg"
      fi
      ;;
    dnf)
      if [ -n "$version" ]; then
        sudo dnf install -y "${pkg}-${version}"
      else
        sudo dnf install -y "$pkg"
      fi
      ;;
    yum)
      if [ -n "$version" ]; then
        sudo yum install -y "${pkg}-${version}"
      else
        sudo yum install -y "$pkg"
      fi
      ;;
    pacman)
      if [ -n "$version" ]; then
        log_warning "pacman: version pinning not supported via CLI; installing latest $pkg"
      fi
      sudo pacman -S --noconfirm "$pkg"
      ;;
    zypper)
      if [ -n "$version" ]; then
        sudo zypper install -y "${pkg}=${version}"
      else
        sudo zypper install -y "$pkg"
      fi
      ;;
    brew)
      if [ -n "$version" ]; then
        brew install "${pkg}@${version}" 2>/dev/null \
          || { log_warning "brew: versioned formula ${pkg}@${version} not found; installing latest"; brew install "$pkg"; }
      else
        brew install "$pkg"
      fi
      ;;
    flatpak)
      if [ -n "$version" ]; then
        log_warning "flatpak: version pinning not supported; installing latest $pkg"
      fi
      if flatpak remotes 2>/dev/null | grep -q flathub; then
        flatpak install -y flathub "$pkg"
      else
        flatpak install -y "$pkg"
      fi
      ;;
    snap)
      if [ -n "$version" ]; then
        sudo snap install "$pkg" --channel="$version" 2>/dev/null \
          || { log_warning "snap: channel $version not found for $pkg; installing latest"; sudo snap install "$pkg"; }
      else
        sudo snap install "$pkg"
      fi
      ;;
    cargo)
      if [ -n "$version" ]; then
        cargo install "$pkg" --version "$version"
      else
        cargo install "$pkg"
      fi
      ;;
    winget)
      if [ -n "$version" ]; then
        winget install --id "$pkg" -e --version "$version"
      else
        winget install --id "$pkg" -e
      fi
      ;;
    *)
      return 1
      ;;
  esac
}

pm_remove() {
  local pm="$1"
  local pkg="$2"
  case "$pm" in
    apt)     sudo apt-get remove -y "$pkg" ;;
    dnf)     sudo dnf remove -y "$pkg" ;;
    yum)     sudo yum remove -y "$pkg" ;;
    pacman)  sudo pacman -R --noconfirm "$pkg" ;;
    zypper)  sudo zypper remove -y "$pkg" ;;
    brew)    brew uninstall "$pkg" ;;
    flatpak) flatpak uninstall -y "$pkg" ;;
    snap)    sudo snap remove "$pkg" ;;
    cargo)   cargo uninstall "$pkg" ;;
    winget)  winget uninstall --id "$pkg" -e ;;
    *)       return 1 ;;
  esac
}

# FIX (1.7.0): every branch now anchors on the package name instead of doing
# a bare substring grep, which previously let e.g. "firefox" match
# "firefox-esr", or "code" match anything containing "code". This directly
# affects `apply`'s idempotency check (a false positive here means apply
# silently skips installing a package that isn't actually present).
pm_is_installed() {
  local pm="$1"
  local pkg="$2"
  local re
  re="$(regex_escape "$pkg")"
  case "$pm" in
    apt)
      dpkg -l "$pkg" 2>/dev/null | grep -q '^ii'
      ;;
    dnf|yum)
      "$pm" list installed "$pkg" 2>/dev/null | grep -q .
      ;;
    pacman)
      pacman -Q "$pkg" >/dev/null 2>&1
      ;;
    zypper)
      zypper packages --installed-only 2>/dev/null \
        | awk -F'|' -v want="$pkg" '{gsub(/^ +| +$/,"",$3); if ($3==want) f=1} END{exit !f}'
      ;;
    brew)
      brew list "$pkg" >/dev/null 2>&1
      ;;
    flatpak)
      flatpak list --columns=application 2>/dev/null | grep -qx "$re" \
        || flatpak list 2>/dev/null | awk '{print $1}' | grep -qx "$re"
      ;;
    snap)
      snap list 2>/dev/null | awk 'NR>1{print $1}' | grep -qx "$re"
      ;;
    cargo)
      cargo install --list 2>/dev/null | awk '{print $1}' | grep -qx "$re"
      ;;
    winget)
      winget list --id "$pkg" -e 2>/dev/null | grep -qi -- "$re"
      ;;
    *)
      return 1
      ;;
  esac
}

pm_update() {
  local pm="$1"
  case "$pm" in
    apt)     sudo apt-get update ;;
    dnf)     sudo dnf check-update || true ;;
    yum)     sudo yum check-update || true ;;
    pacman)  sudo pacman -Sy ;;
    zypper)  sudo zypper refresh ;;
    brew)    brew update ;;
    flatpak) flatpak update --appstream ;;
    snap)    sudo snap refresh ;;
    winget)  winget source update ;;
    cargo)
      log_warning "cargo: no index update available (use 'pdrx upgrade' to upgrade crates)"
      ;;
    *)
      return 1
      ;;
  esac
}

pm_upgrade() {
  local pm="$1"
  case "$pm" in
    apt)     sudo apt-get upgrade -y ;;
    dnf)     sudo dnf upgrade -y ;;
    yum)     sudo yum update -y ;;
    pacman)  sudo pacman -Su --noconfirm ;;
    zypper)  sudo zypper update -y ;;
    brew)    brew upgrade ;;
    flatpak) flatpak update -y ;;
    snap)    sudo snap refresh ;;
    winget)  winget upgrade --all ;;
    cargo)
      if command -v cargo-install-update >/dev/null 2>&1; then
        cargo install-update -a
      else
        log_warning "cargo: cargo-update not installed."
        printf "Install cargo-update now to enable crate upgrades? [y/N]: "
        local ans
        read -r ans
        if [[ "$ans" =~ ^[Yy]$ ]]; then
          if cargo install cargo-update; then
            cargo install-update -a
          else
            log_warning "cargo: failed to install cargo-update"
          fi
        else
          log_warning "cargo: skipping upgrade. Run 'cargo install cargo-update' manually."
        fi
      fi
      ;;
    *)
      return 1
      ;;
  esac
}

# =============================================================================
# REPO / PPA / THIRD-PARTY SOURCES  (new in 1.7.0)
# =============================================================================
#
# sources.conf format (one entry per line):
#   pm:key=value[,value...]
#
#   apt:ppa=ppa:deadsnakes/ppa
#   apt:repo=deb [signed-by=/etc/apt/keyrings/docker.gpg] https://download.docker.com/linux/ubuntu jammy stable|/etc/apt/keyrings/docker.gpg|https://download.docker.com/linux/ubuntu/gpg
#   dnf:repo=https://download.docker.com/linux/fedora/docker-ce.repo
#   zypper:repo=https://download.opensuse.org/repositories/.../repo.repo
#   flatpak:remote=flathub|https://flathub.org/repo/flathub.flatpakrepo
#
# This exists because `pdrx apply` on a genuinely fresh machine previously
# failed silently for any package outside default distro repos — the #1
# reason a from-scratch apply didn't actually reproduce a real dev machine.
# pacman is intentionally NOT supported here: editing /etc/pacman.conf
# programmatically is high-risk (it's a single shared file, not a drop-in
# directory) and AUR helpers are out of scope — track those manually.

sources_add() {
  local pm="$1" kind="$2"; shift 2
  mkdir -p "$PDRX_CONFIG"
  touch "$SOURCES_CONF"
  local line="$pm:$kind=$*"
  # de-dupe identical lines only; sources can legitimately repeat similar URLs
  grep -qFx "$line" "$SOURCES_CONF" 2>/dev/null || echo "$line" >> "$SOURCES_CONF"
}

run_source() {
  require_initialized
  local sub="${1:-}"; shift || true
  case "$sub" in
    add)
      local pm="${1:-}"; shift || true
      [ -z "$pm" ] && { log_error "Usage: pdrx source add <apt|dnf|zypper|flatpak> ..."; exit 1; }
      case "$pm" in
        apt)
          local ppa="${1:-}"
          [ -z "$ppa" ] && { log_error "Usage: pdrx source add apt <ppa:owner/name | repo-line>"; exit 1; }
          if [ "${DRY_RUN:-false}" = "true" ]; then
            log_info "[dry-run] would add apt source: $ppa"
            return 0
          fi
          if [[ "$ppa" == ppa:* ]]; then
            command -v add-apt-repository >/dev/null 2>&1 \
              || { log_error "add-apt-repository not found (install software-properties-common)"; exit 1; }
            sudo add-apt-repository -y "$ppa"
            sources_add apt ppa "$ppa"
          else
            log_error "For raw apt repo lines use: pdrx source add apt-repo <sources-list-line> <keyring-path> <key-url>"
            exit 1
          fi
          sudo apt-get update
          log_action "source_add" "apt" "$ppa" "ok"
          log_success "Added apt source: $ppa"
          ;;
        apt-repo)
          local repo_line="${1:-}" keyring="${2:-}" key_url="${3:-}"
          [ -z "$repo_line" ] || [ -z "$keyring" ] || [ -z "$key_url" ] && {
            log_error "Usage: pdrx source add apt-repo <'deb ... suite comp'> <keyring-path> <key-url>"; exit 1; }
          if [ "${DRY_RUN:-false}" = "true" ]; then
            log_info "[dry-run] would fetch key $key_url -> $keyring and add: $repo_line"
            return 0
          fi
          sudo mkdir -p "$(dirname "$keyring")"
          curl -fsSL "$key_url" | sudo gpg --dearmor -o "$keyring"
          local list_name
          list_name="pdrx-$(echo "$repo_line" | md5sum | cut -c1-8).list"
          echo "$repo_line" | sudo tee "/etc/apt/sources.list.d/$list_name" >/dev/null
          sources_add apt repo "$repo_line|$keyring|$key_url"
          sudo apt-get update
          log_action "source_add" "apt" "$repo_line" "ok"
          log_success "Added apt repo (key: $keyring)"
          ;;
        dnf|zypper)
          local repo_url="${1:-}"
          [ -z "$repo_url" ] && { log_error "Usage: pdrx source add $pm <repo-url-or-.repo-file>"; exit 1; }
          if [ "${DRY_RUN:-false}" = "true" ]; then
            log_info "[dry-run] would add $pm repo: $repo_url"
            return 0
          fi
          if [ "$pm" = "dnf" ]; then
            sudo dnf config-manager --add-repo "$repo_url"
          else
            sudo zypper addrepo -f "$repo_url" "pdrx-$(echo "$repo_url" | md5sum | cut -c1-8)"
            sudo zypper --gpg-auto-import-keys refresh
          fi
          sources_add "$pm" repo "$repo_url"
          log_action "source_add" "$pm" "$repo_url" "ok"
          log_success "Added $pm repo: $repo_url"
          ;;
        flatpak)
          local name="${1:-}" url="${2:-}"
          [ -z "$name" ] || [ -z "$url" ] && { log_error "Usage: pdrx source add flatpak <name> <repo-url>"; exit 1; }
          if [ "${DRY_RUN:-false}" = "true" ]; then
            log_info "[dry-run] would add flatpak remote: $name -> $url"
            return 0
          fi
          flatpak remote-add --if-not-exists "$name" "$url"
          sources_add flatpak remote "$name|$url"
          log_action "source_add" "flatpak" "$name" "ok"
          log_success "Added flatpak remote: $name"
          ;;
        *)
          log_error "Unsupported: pdrx source add $pm (supported: apt, apt-repo, dnf, zypper, flatpak)"
          exit 1
          ;;
      esac
      ;;
    list)
      log_header "Declared sources"
      if [ -s "$SOURCES_CONF" ]; then
        cat "$SOURCES_CONF"
      else
        log_info "No sources declared."
      fi
      ;;
    apply)
      _apply_sources
      ;;
    *)
      log_error "Usage: pdrx source <add|list|apply> ..."
      exit 1
      ;;
  esac
}

# Re-adds every declared source; used by `pdrx apply` and `pdrx source apply`
# so a from-scratch machine gets repos wired up BEFORE package install runs.
_apply_sources() {
  [ -f "$SOURCES_CONF" ] || return 0
  log_header "Applying declared sources"
  local line
  while IFS= read -r line; do
    [ -z "$line" ] && continue
    [[ "$line" == \#* ]] && continue
    local pm="${line%%:*}" rest="${line#*:}"
    local kind="${rest%%=*}" val="${rest#*=}"
    case "$pm:$kind" in
      apt:ppa)
        if [ "${DRY_RUN:-false}" = "true" ]; then
          log_info "[dry-run] would ensure apt ppa: $val"
        elif pm_available apt; then
          sudo add-apt-repository -y "$val" 2>/dev/null || true
        fi
        ;;
      apt:repo)
        local repo_line="${val%%|*}" rem="${val#*|}"
        local keyring="${rem%%|*}" key_url="${rem#*|}"
        if [ "${DRY_RUN:-false}" = "true" ]; then
          log_info "[dry-run] would ensure apt repo: $repo_line"
        elif pm_available apt; then
          [ -f "$keyring" ] || { sudo mkdir -p "$(dirname "$keyring")"; curl -fsSL "$key_url" | sudo gpg --dearmor -o "$keyring" 2>/dev/null || true; }
          local list_name
          list_name="pdrx-$(echo "$repo_line" | md5sum | cut -c1-8).list"
          [ -f "/etc/apt/sources.list.d/$list_name" ] \
            || echo "$repo_line" | sudo tee "/etc/apt/sources.list.d/$list_name" >/dev/null
        fi
        ;;
      dnf:repo)
        if [ "${DRY_RUN:-false}" = "true" ]; then
          log_info "[dry-run] would ensure dnf repo: $val"
        else
          pm_available dnf && sudo dnf config-manager --add-repo "$val" 2>/dev/null || true
        fi
        ;;
      zypper:repo)
        if [ "${DRY_RUN:-false}" = "true" ]; then
          log_info "[dry-run] would ensure zypper repo: $val"
        else
          pm_available zypper && sudo zypper addrepo -f "$val" "pdrx-$(echo "$val" | md5sum | cut -c1-8)" 2>/dev/null || true
        fi
        ;;
      flatpak:remote)
        local name="${val%%|*}" url="${val#*|}"
        if [ "${DRY_RUN:-false}" = "true" ]; then
          log_info "[dry-run] would ensure flatpak remote: $name"
        else
          pm_available flatpak && flatpak remote-add --if-not-exists "$name" "$url" 2>/dev/null || true
        fi
        ;;
      *) ;;
    esac
  done < "$SOURCES_CONF"
  if pm_available apt && [ "${DRY_RUN:-false}" != "true" ]; then
    sudo apt-get update 2>/dev/null || true
  fi
  log_success "Sources applied"
}

# =============================================================================
# SYSTEMD UNITS  (new in 1.7.0)
# =============================================================================
#
# systemd.conf format: scope:unit
#   system:kanata.service
#   user:pipewire.service
#
# Only ENABLED units are captured (state, not just presence) — mirrors the
# "user-initiated only" philosophy of pm_list_installed. Masked/disabled
# units are intentionally not touched by apply (too destructive to automate).

run_sync_systemd() {
  require_initialized
  mkdir -p "$PDRX_CONFIG"
  local tmp
  tmp=$(mktemp)
  if command -v systemctl >/dev/null 2>&1; then
    systemctl list-unit-files --state=enabled --no-legend 2>/dev/null \
      | awk '{print $1}' | grep -v '^$' \
      | while IFS= read -r u; do echo "system:$u" >> "$tmp"; done || true
    systemctl --user list-unit-files --state=enabled --no-legend 2>/dev/null \
      | awk '{print $1}' | grep -v '^$' \
      | while IFS= read -r u; do echo "user:$u" >> "$tmp"; done || true
  fi
  {
    echo "# pdrx declarative systemd units"
    echo "# Format: system:unit.service  or  user:unit.service"
    echo "# Only ENABLED units are tracked. Masked/disabled units are not managed."
    echo "# Synced: $(date_iso_seconds)"
    echo ""
    sort -u "$tmp" 2>/dev/null || true
  } > "$SYSTEMD_CONF"
  rm -f "$tmp"
  log_success "Synced enabled systemd units to $SYSTEMD_CONF"
}

run_apply_systemd() {
  [ -f "$SYSTEMD_CONF" ] || return 0
  command -v systemctl >/dev/null 2>&1 || return 0
  log_header "Applying declared systemd units"
  local line count=0
  while IFS= read -r line; do
    [ -z "$line" ] && continue
    [[ "$line" == \#* ]] && continue
    local scope="${line%%:*}" unit="${line#*:}"
    [ -z "$unit" ] && continue
    case "$scope" in
      system)
        if systemctl is-enabled "$unit" >/dev/null 2>&1; then
          continue
        fi
        if [ "${DRY_RUN:-false}" = "true" ]; then
          log_info "[dry-run] would enable (system): $unit"
        else
          sudo systemctl enable "$unit" 2>/dev/null \
            && { count=$((count+1)); log_action "systemd_enable" "system" "$unit" "ok"; } \
            || log_warning "Could not enable system unit: $unit (not installed?)"
        fi
        ;;
      user)
        if systemctl --user is-enabled "$unit" >/dev/null 2>&1; then
          continue
        fi
        if [ "${DRY_RUN:-false}" = "true" ]; then
          log_info "[dry-run] would enable (user): $unit"
        else
          systemctl --user enable "$unit" 2>/dev/null \
            && { count=$((count+1)); log_action "systemd_enable" "user" "$unit" "ok"; } \
            || log_warning "Could not enable user unit: $unit (not installed?)"
        fi
        ;;
      *) ;;
    esac
  done < "$SYSTEMD_CONF"
  log_success "systemd units applied: $count newly enabled"
}

# =============================================================================
# HOOKS  (new in 1.7.0)
# =============================================================================
#
# ~/.pdrx/config/hooks/post-apply.sh, if present and executable, is sourced
# at the end of `pdrx apply`. This is the deliberate, narrow escape hatch for
# the handful of things that can't be expressed declaratively — e.g. reloading
# udev rules after installing a kanata config, or `gnome-extensions enable`.
# It is versioned/backed-up exactly like dotfiles. Kept singular and opt-in
# on purpose: pdrx is not becoming a general task runner.

run_apply_hooks() {
  local hook="$HOOKS_DIR/post-apply.sh"
  [ -x "$hook" ] || return 0
  log_header "Running post-apply hook"
  if [ "${DRY_RUN:-false}" = "true" ]; then
    log_info "[dry-run] would run: $hook"
    return 0
  fi
  if ( "$hook" ); then
    log_action "hook" "" "post-apply" "ok"
    log_success "post-apply hook completed"
  else
    log_action "hook" "" "post-apply" "failed"
    log_warning "post-apply hook exited non-zero"
  fi
}

run_hook_edit() {
  mkdir -p "$HOOKS_DIR"
  local hook="$HOOKS_DIR/post-apply.sh"
  if [ ! -f "$hook" ]; then
    cat > "$hook" << 'HOOKEOF'
#!/usr/bin/env bash
# Runs at the end of `pdrx apply`. Keep it idempotent — it may run many times.
set -euo pipefail

# Example:
# sudo udevadm control --reload-rules && sudo udevadm trigger
# gnome-extensions enable someextension@example.com
HOOKEOF
    chmod +x "$hook"
    log_success "Created $hook"
  else
    log_info "Hook already exists: $hook"
  fi
}

# =============================================================================
# DESKTOP ENVIRONMENT
# =============================================================================

_cp_file() { if [ -f "$1" ]; then cp    "$1" "$2" 2>/dev/null || true; fi; }
_cp_dir()  { if [ -d "$1" ]; then cp -R "$1" "$2" 2>/dev/null || true; fi; }

get_desktop_id() {
  local xdg="${XDG_CURRENT_DESKTOP:-}"
  local gdm="${GDMSESSION:-}"
  [ "$(uname -s)" = "Darwin" ] && { echo "macos"; return; }
  case "${xdg}${gdm}" in
    *[Hh][Yy][Pp][Rr]*)                     echo "hyprland"; return ;;
    *[Gg][Nn][Oo][Mm][Ee]*)                  echo "gnome";    return ;;
    *[Pp][Ll][Aa][Ss][Mm][Aa]*|*[Kk][Dd][Ee]*) echo "kde";   return ;;
    *[Xx][Ff][Cc][Ee]*)                      echo "xfce";     return ;;
    *[Ss][Ww][Aa][Yy]*)                      echo "sway";     return ;;
    *[Ii]3*)                                 echo "i3";        return ;;
  esac
  [ "${XDG_SESSION_TYPE:-}" = "wayland" ] && [ -n "${WAYLAND_DISPLAY:-}" ] \
    && { echo "wayland"; return; }
  echo "unknown"
}

export_desktop_common() {
  local out="$1"
  mkdir -p "$out/common"
  _cp_file "$HOME/.config/mimeapps.list"     "$out/common/"
  _cp_file "$HOME/.config/user-dirs.dirs"    "$out/common/"
  _cp_file "$HOME/.config/user-dirs.locale"  "$out/common/"
  _cp_dir  "$HOME/.config/fontconfig"        "$out/common/"
  _cp_file "$HOME/.Xresources"               "$out/common/"
  _cp_file "$HOME/.xinitrc"                  "$out/common/"
  _cp_file "$HOME/.xsession"                 "$out/common/"
  _cp_dir  "$HOME/.local/share/applications" "$out/common/"
}

export_desktop_state() {
  local out="${DESKTOP_EXPORT}"
  local de
  de="$(get_desktop_id)"
  mkdir -p "$out"
  case "$de" in
    gnome)
      if command -v dconf >/dev/null 2>&1; then
        mkdir -p "$out/dconf"
        dconf dump / > "$out/dconf/user.txt" 2>/dev/null || true
      fi
      if command -v gsettings >/dev/null 2>&1; then
        mkdir -p "$out/gsettings"
        while IFS= read -r schema; do
          gsettings list-recursively "$schema" 2>/dev/null > "$out/gsettings/${schema}.txt" || true
        done < <(gsettings list-schemas 2>/dev/null)
        gsettings get org.gnome.shell enabled-extensions 2>/dev/null \
          > "$out/gnome-enabled-extensions.txt" || true
      fi
      _cp_dir "$HOME/.config/gnome"       "$out/"
      _cp_dir "$HOME/.config/gnome-shell" "$out/"
      _cp_dir "$HOME/.config/gtk-3.0"     "$out/"
      _cp_dir "$HOME/.config/gtk-4.0"     "$out/"
      # Fix: copy contents of extensions dir, not the dir itself
      if [ -d "$HOME/.local/share/gnome-shell/extensions" ]; then
        mkdir -p "$out/gnome-shell-extensions"
        cp -R "$HOME/.local/share/gnome-shell/extensions/"* "$out/gnome-shell-extensions/" 2>/dev/null || true
      fi
      ;;
    kde)
      mkdir -p "$out/.config" "$out/.local"
      while IFS= read -r f; do
        cp -R "$f" "$out/.config/" 2>/dev/null || true
      done < <(find "$HOME/.config" -maxdepth 1 \( -name 'kde*' -o -name 'plasma*' \
        -o -name 'kwin*' -o -name 'kscreen*' -o -name 'kglobal*' \) 2>/dev/null)
      ;;
    xfce)
      _cp_dir "$HOME/.config/xfce4"  "$out/"
      _cp_dir "$HOME/.config/Thunar" "$out/"
      ;;
    i3)
      if [ -f "$HOME/.config/i3/config" ]; then
        mkdir -p "$out/i3"
        cp "$HOME/.config/i3/config" "$out/i3/config" 2>/dev/null || true
      fi
      _cp_dir "$HOME/.config/i3status" "$out/"
      _cp_dir "$HOME/.config/i3blocks" "$out/"
      ;;
    sway)
      if [ -f "$HOME/.config/sway/config" ]; then
        mkdir -p "$out/sway"
        cp "$HOME/.config/sway/config" "$out/sway/config" 2>/dev/null || true
      fi
      _cp_dir "$HOME/.config/waybar" "$out/"
      _cp_dir "$HOME/.config/swaync" "$out/"
      _cp_dir "$HOME/.config/foot"   "$out/"
      ;;
    hyprland)
      _cp_dir "$HOME/.config/hypr"   "$out/"
      _cp_dir "$HOME/.config/waybar" "$out/"
      _cp_dir "$HOME/.config/wofi"   "$out/"
      ;;
    *) ;;
  esac
  export_desktop_common "$out"
  echo "$de" > "$out/current-desktop.txt"
}

restore_desktop_common() {
  local out="$1"
  [ ! -d "$out/common" ] && return 0
  mkdir -p "$HOME/.config" "$HOME/.local/share"
  _cp_file "$out/common/mimeapps.list"    "$HOME/.config/"
  _cp_file "$out/common/user-dirs.dirs"   "$HOME/.config/"
  _cp_file "$out/common/user-dirs.locale" "$HOME/.config/"
  _cp_dir  "$out/common/fontconfig"       "$HOME/.config/"
  _cp_file "$out/common/.Xresources"      "$HOME/"
  _cp_file "$out/common/.xinitrc"         "$HOME/"
  _cp_file "$out/common/.xsession"        "$HOME/"
  _cp_dir  "$out/common/applications"     "$HOME/.local/share/"
}

restore_desktop_state() {
  local out="${DESKTOP_EXPORT}"
  [ ! -f "$out/current-desktop.txt" ] && return 0
  local de
  de=$(cat "$out/current-desktop.txt")
  restore_desktop_common "$out"
  case "$de" in
    gnome)
      if [ -f "$out/dconf/user.txt" ] && command -v dconf >/dev/null 2>&1; then
        dconf load / < "$out/dconf/user.txt" 2>/dev/null || true
      fi
      _cp_dir "$out/gnome"       "$HOME/.config/"
      _cp_dir "$out/gnome-shell" "$HOME/.config/"
      _cp_dir "$out/gtk-3.0"     "$HOME/.config/"
      _cp_dir "$out/gtk-4.0"     "$HOME/.config/"
      # Fix: copy contents, not the dir itself
      if [ -d "$out/gnome-shell-extensions" ]; then
        mkdir -p "$HOME/.local/share/gnome-shell/extensions"
        cp -R "$out/gnome-shell-extensions/"* "$HOME/.local/share/gnome-shell/extensions/" 2>/dev/null || true
      fi
      ;;
    kde)
      if [ -d "$out/.config" ]; then cp -R "$out/.config/"* "$HOME/.config/" 2>/dev/null || true; fi
      if [ -d "$out/.local" ];  then cp -R "$out/.local/"*  "$HOME/.local/"  2>/dev/null || true; fi
      ;;
    xfce)
      _cp_dir "$out/xfce4"  "$HOME/.config/"
      _cp_dir "$out/Thunar" "$HOME/.config/"
      ;;
    i3)
      if [ -f "$out/i3/config" ]; then
        mkdir -p "$HOME/.config/i3"
        cp "$out/i3/config" "$HOME/.config/i3/config" 2>/dev/null || true
      fi
      _cp_dir "$out/i3status" "$HOME/.config/"
      _cp_dir "$out/i3blocks" "$HOME/.config/"
      ;;
    sway)
      if [ -f "$out/sway/config" ]; then
        mkdir -p "$HOME/.config/sway"
        cp "$out/sway/config" "$HOME/.config/sway/config" 2>/dev/null || true
      fi
      _cp_dir "$out/waybar" "$HOME/.config/"
      _cp_dir "$out/swaync" "$HOME/.config/"
      _cp_dir "$out/foot"   "$HOME/.config/"
      ;;
    hyprland)
      _cp_dir "$out/hypr"   "$HOME/.config/"
      _cp_dir "$out/waybar" "$HOME/.config/"
      _cp_dir "$out/wofi"   "$HOME/.config/"
      ;;
    *) ;;
  esac
}

# =============================================================================
# LOGGING
# =============================================================================

RED=''; GREEN=''; YELLOW=''; BLUE=''; CYAN=''; BOLD=''; NC=''
[ -t 1 ] && RED=$'\033[0;31m' GREEN=$'\033[0;32m' YELLOW=$'\033[1;33m' \
            BLUE=$'\033[0;34m' CYAN=$'\033[0;36m' BOLD=$'\033[1m' NC=$'\033[0m'

log_info()    { [ "${QUIET:-false}" != "true" ] && echo "${BLUE}[INFO]${NC} $*";     true; }
log_success() { [ "${QUIET:-false}" != "true" ] && echo "${GREEN}[SUCCESS]${NC} $*"; true; }
log_warning() { echo "${YELLOW}[WARNING]${NC} $*"; }
log_error()   { echo "${RED}[ERROR]${NC} $*" >&2; }
log_header()  { [ "${QUIET:-false}" != "true" ] && printf "\n%s━━━ %s ━━━%s\n\n" "${BOLD}${CYAN}" "$*" "${NC}"; true; }
log_debug()   { [ "${DEBUG:-false}" = "true" ] && echo "${YELLOW}[DEBUG]${NC} $*" >&2; true; }

# =============================================================================
# INIT & STATE
# =============================================================================

is_initialized() {
  [ -f "$PDRX_STATE/initialized" ]
}

require_initialized() {
  log_debug "require_initialized: checking $PDRX_STATE/initialized"
  if ! is_initialized; then
    log_error "pdrx is not initialized. Run: pdrx init"
    exit 1
  fi
}

mark_initialized() {
  mkdir -p "$PDRX_CONFIG" "$PDRX_BACKUP" "$PDRX_STATE" "$DOTFILES_DIR" "$HOOKS_DIR"
  touch "$PACKAGES_CONF" 2>/dev/null || true
  touch "$SOURCES_CONF" 2>/dev/null || true
  touch "$SYSTEMD_CONF" 2>/dev/null || true
  touch "$TRACKED_DOTFILES" 2>/dev/null || true
  date_iso_seconds > "$PDRX_STATE/initialized"
  echo "$VERSION" > "$PDRX_STATE/version"
  detect_os_id > "$PDRX_STATE/os-id"
}

load_packages_conf() {
  [ -f "$PACKAGES_CONF" ] || return 0
  grep -v '^#' "$PACKAGES_CONF" | grep -v '^$' | sort -u
}

_parse_conf_line() {
  local line="$1"
  local _rest
  PARSED_PM="${line%%:*}"
  _rest="${line#*:}"
  if [[ "$_rest" == *=* ]]; then
    PARSED_PKG="${_rest%%=*}"
    PARSED_VERSION="${_rest#*=}"
  else
    PARSED_PKG="$_rest"
    PARSED_VERSION=""
  fi
}

# Atomic write, with pkg-name safely escaped before use in the grep pattern.
append_packages_conf() {
  local pm="$1"
  local pkg="$2"
  local version="${3:-}"
  local line
  if [ -n "$version" ]; then
    line="$pm:${pkg}=${version}"
  else
    line="$pm:$pkg"
  fi
  local re
  re="$(regex_escape "$pkg")"
  local tmp
  tmp=$(mktemp "${PACKAGES_CONF}.XXXXXX")
  if [ -f "$PACKAGES_CONF" ]; then
    grep -vE "^${pm}:${re}(=.*)?$" "$PACKAGES_CONF" > "$tmp" || true
  fi
  echo "$line" >> "$tmp"
  mv "$tmp" "$PACKAGES_CONF"
}

remove_from_packages_conf() {
  local pm="$1"
  local pkg="$2"
  [ -f "$PACKAGES_CONF" ] || return 0
  local re
  re="$(regex_escape "$pkg")"
  local tmp
  tmp=$(mktemp "${PACKAGES_CONF}.XXXXXX")
  grep -vE "^${pm}:${re}(=.*)?$" "$PACKAGES_CONF" > "$tmp" || true
  mv "$tmp" "$PACKAGES_CONF"
}

# =============================================================================
# COMMANDS
# =============================================================================

run_init() {
  log_header "Initialize pdrx"
  if is_initialized; then
    log_info "Already initialized at $PDRX_HOME"
  else
    mark_initialized
    log_success "Initialized pdrx at $PDRX_HOME"
    run_sync_desktop 2>/dev/null || true
  fi
  local pms
  pms=$(detect_available_pms)
  log_info "Available package managers: $pms"
}

# FIX (1.7.0): `grep -cv PATTERN file || echo 0` double-prints "0\n0" for a
# zero-match file, because grep -c already writes "0" to stdout before
# exiting 1 (no match), and the `|| echo 0` fallback then adds a second "0".
# Pre-existing bug in run_status; fixed here and used for all new counters.
_count_conf_lines() {
  local file="$1"
  [ -f "$file" ] || { echo 0; return; }
  grep -cv '^#\|^$' "$file" 2>/dev/null | head -1
}

run_status() {
  require_initialized
  log_header "pdrx Status"
  echo "Config:     $PDRX_CONFIG"
  echo "Backups:    $PDRX_BACKUP"
  echo "OS:         $(detect_os_id) ($(detect_os_id_like))"
  echo "Desktop:    $(get_desktop_id)"
  echo "PMs:        $(detect_available_pms)"
  echo "Packages:   $(_count_conf_lines "$PACKAGES_CONF") in declarative config"
  echo "Sources:    $(_count_conf_lines "$SOURCES_CONF") declared"
  echo "Systemd:    $(_count_conf_lines "$SYSTEMD_CONF") enabled units tracked"
  echo "Hook:       $([ -x "$HOOKS_DIR/post-apply.sh" ] && echo "present" || echo "none")"
  echo "Backups:    $(find "$PDRX_BACKUP" -mindepth 1 -maxdepth 1 2>/dev/null | wc -l)"
}

run_install() {
  require_initialized
  local pkgs=()
  local PIN=false
  local PIN_VERSION=""

  while [ $# -gt 0 ]; do
    case "$1" in
      --pin=*)  PIN=true; PIN_VERSION="${1#--pin=}"; shift ;;
      --pin)    PIN=true; shift ;;
      *)        pkgs+=("$1"); shift ;;
    esac
  done

  log_debug "run_install: pkgs=(${pkgs[*]:-}) PIN=$PIN PIN_VERSION=$PIN_VERSION"
  [ ${#pkgs[@]} -eq 0 ] && { log_error "Usage: pdrx install [--pin[=VERSION]] <pkg> [pkg...]"; exit 1; }

  local pms
  read -ra pms <<< "$(detect_available_pms)"
  [ ${#pms[@]} -eq 0 ] && { log_error "No package managers found."; exit 1; }

  local pkg
  for pkg in "${pkgs[@]}"; do
    log_header "Install: $pkg"
    local pm
    if [ ${#pms[@]} -eq 1 ]; then
      pm="${pms[0]}"
      log_info "Using $pm (only PM available)"
    else
      echo "Select package manager for '$pkg':"
      local i=1
      local p
      for p in "${pms[@]}"; do echo "  $i) $p"; i=$((i+1)); done
      printf "Choice [1-%d]: " "${#pms[@]}"
      read -r choice
      choice="${choice:-1}"
      pm="${pms[$((choice-1))]}"
    fi

    if pm_available "$pm"; then
      local recorded_version="$PIN_VERSION"
      if pm_install "$pm" "$pkg" "$PIN_VERSION"; then
        if [ "$PIN" = "true" ] && [ -z "$recorded_version" ]; then
          recorded_version=$(pm_installed_version "$pm" "$pkg" 2>/dev/null || echo "")
          if [ -z "$recorded_version" ]; then
            log_warning "Could not detect installed version of $pkg; recording without pin"
          fi
        fi
        if [ "$PIN" = "true" ] && [ -n "$recorded_version" ]; then
          append_packages_conf "$pm" "$pkg" "$recorded_version"
          log_success "Installed and pinned $pkg=$recorded_version via $pm"
        else
          append_packages_conf "$pm" "$pkg"
          log_success "Installed $pkg via $pm"
        fi
        log_action "install" "$pm" "$pkg" "ok" "${recorded_version:-}"
      else
        log_action "install" "$pm" "$pkg" "failed"
      fi
    else
      log_error "PM $pm not available"
    fi
  done
}

run_install_with_pm() {
  require_initialized
  local pm="$1"
  shift
  local pkgs=()
  local PIN=false
  local PIN_VERSION=""

  while [ $# -gt 0 ]; do
    case "$1" in
      --pin=*)  PIN=true; PIN_VERSION="${1#--pin=}"; shift ;;
      --pin)    PIN=true; shift ;;
      *)        pkgs+=("$1"); shift ;;
    esac
  done

  [ ${#pkgs[@]} -eq 0 ] && { log_error "Usage: pdrx install --pm <pm> [--pin[=VERSION]] <pkg> [pkg...]"; exit 1; }
  pm_available "$pm" || { log_error "PM $pm not available"; exit 1; }
  log_debug "run_install_with_pm: pm=$pm pkgs=(${pkgs[*]:-}) PIN=$PIN PIN_VERSION=$PIN_VERSION"

  local pkg
  for pkg in "${pkgs[@]}"; do
    local recorded_version="$PIN_VERSION"
    if pm_install "$pm" "$pkg" "$PIN_VERSION"; then
      if [ "$PIN" = "true" ] && [ -z "$recorded_version" ]; then
        recorded_version=$(pm_installed_version "$pm" "$pkg" 2>/dev/null || echo "")
        if [ -z "$recorded_version" ]; then
          log_warning "Could not detect installed version of $pkg; recording without pin"
        fi
      fi
      if [ "$PIN" = "true" ] && [ -n "$recorded_version" ]; then
        append_packages_conf "$pm" "$pkg" "$recorded_version"
        log_success "Installed and pinned $pkg=$recorded_version via $pm"
      else
        append_packages_conf "$pm" "$pkg"
        log_success "Installed $pkg via $pm"
      fi
      log_action "install" "$pm" "$pkg" "ok" "${recorded_version:-}"
    else
      log_action "install" "$pm" "$pkg" "failed"
    fi
  done
}

run_remove() {
  require_initialized
  local pkgs=("$@")
  [ ${#pkgs[@]} -eq 0 ] && { log_error "Usage: pdrx remove <pkg> [pkg...]"; exit 1; }

  local pkg
  for pkg in "${pkgs[@]}"; do
    local re
    re="$(regex_escape "$pkg")"
    local line
    line=$(grep -E ":${re}(=.*)?$" "$PACKAGES_CONF" 2>/dev/null | head -1)
    if [ -n "$line" ]; then
      local pm="${line%%:*}"
      if [ "${DRY_RUN:-false}" = "true" ]; then
        log_info "[dry-run] would remove: $pkg (via $pm)"
        continue
      fi
      log_info "Removing $pkg (from $pm)"
      if pm_available "$pm"; then
        pm_remove "$pm" "$pkg" 2>/dev/null || true
      else
        log_info "PM $pm not available; removing from config only"
      fi
      remove_from_packages_conf "$pm" "$pkg"
      log_action "remove" "$pm" "$pkg" "ok"
      log_success "Removed $pkg"
    else
      log_warning "Package $pkg not in declarative config. Checking all PMs..."
      local pm
      for pm in $(detect_available_pms); do
        if pm_is_installed "$pm" "$pkg" 2>/dev/null; then
          if [ "${DRY_RUN:-false}" = "true" ]; then
            log_info "[dry-run] would remove: $pkg (via $pm)"
            break
          fi
          if pm_remove "$pm" "$pkg"; then
            remove_from_packages_conf "$pm" "$pkg"
            log_action "remove" "$pm" "$pkg" "ok"
            log_success "Removed $pkg from $pm"
          fi
          break
        fi
      done
    fi
  done
}

run_list() {
  require_initialized
  log_header "Installed packages (declarative config)"
  if [ -s "$PACKAGES_CONF" ]; then
    while IFS= read -r line; do
      [ -z "$line" ] && continue
      [[ "$line" == \#* ]] && continue
      [[ "$line" =~ ^[a-z]+:.+ ]] || continue
      echo "  $line"
    done < "$PACKAGES_CONF"
  else
    log_info "No packages in config. Run 'pdrx sync' to capture current state."
  fi
}

run_search() {
  log_debug "run_search: args=($*)"
  local term=""
  local pm=""
  local pm_nums=()
  local PARALLEL_SEARCH=false

  while [ $# -gt 0 ]; do
    case "$1" in
      --pm)       pm="${2:-}"; shift 2 ;;
      --parallel) PARALLEL_SEARCH=true; shift ;;
      -*)         shift ;;
      *)
        term="$1"
        shift
        while [ $# -gt 0 ] && [[ "$1" =~ ^[0-9]+$ ]]; do
          pm_nums+=("$1")
          shift
        done
        break
        ;;
    esac
  done
  [ -z "$term" ] && { log_error "Usage: pdrx search [--parallel] <term> [--pm PM] [num ...]"; exit 1; }

  local pms
  read -ra pms <<< "$(detect_available_pms)"
  [ ${#pms[@]} -eq 0 ] && { log_error "No package managers found."; exit 1; }

  _run_search_pms() {
    local t="$1"
    shift
    local to_search=("$@")

    if [ "$PARALLEL_SEARCH" = "true" ] && [ ${#to_search[@]} -gt 1 ]; then
      local tmpdir
      tmpdir=$(mktemp -d)
      local pids=()
      local idx=0
      local p

      printf "\n%sSearching '%s' across %d package manager(s)…%s\n\n" \
        "${BOLD}${CYAN}" "$t" "${#to_search[@]}" "${NC}"
      for p in "${to_search[@]}"; do
        printf "  %s[queued]%s %s\n" "${YELLOW}" "${NC}" "$p"
      done
      echo ""

      for p in "${to_search[@]}"; do
        local outfile="$tmpdir/${idx}_${p}"
        local donefile="$tmpdir/${idx}_${p}.done"
        (
          {
            echo ""
            printf "%s━━━ %s ━━━%s\n\n" "${BOLD}${CYAN}" "$p" "${NC}"
            _print_search_header
            pm_search_formatted "$t" "$p" 2>/dev/null || true
            echo ""
          } > "$outfile"
          touch "$donefile"
        ) &
        pids+=($!)
        idx=$((idx + 1))
      done

      idx=0
      local pid
      for pid in "${pids[@]}"; do
        p="${to_search[$idx]}"
        wait "$pid" 2>/dev/null || true
        if [ -f "$tmpdir/${idx}_${p}.done" ]; then
          printf "%s[done]%s %s\n" "${GREEN}" "${NC}" "$p"
        else
          printf "%s[error]%s %s (search failed)\n" "${RED}" "${NC}" "$p"
        fi
        cat "$tmpdir/${idx}_${p}" 2>/dev/null || true
        idx=$((idx + 1))
      done
      rm -rf "$tmpdir"
    else
      local p
      for p in "${to_search[@]}"; do
        log_header "$p"
        _print_search_header
        pm_search_formatted "$t" "$p" 2>/dev/null || true
        echo ""
      done
    fi
  }

  if [ -n "$pm" ]; then
    pm_available "$pm" || { log_error "PM $pm not available"; exit 1; }
    _print_search_header
    pm_search_formatted "$term" "$pm" 2>/dev/null || true
    return
  fi

  if [ ${#pm_nums[@]} -gt 0 ]; then
    local selected=()
    local n
    for n in "${pm_nums[@]}"; do
      if [ "$n" -ge 1 ] && [ "$n" -le "${#pms[@]}" ]; then
        selected+=("${pms[$((n-1))]}")
      fi
    done
    [ ${#selected[@]} -eq 0 ] && { log_error "No valid PM numbers (use 1-${#pms[@]})"; exit 1; }
    _run_search_pms "$term" "${selected[@]}"
    return
  fi

  if [ ${#pms[@]} -eq 1 ] || [ "${YES:-false}" = "true" ]; then
    _run_search_pms "$term" "${pms[@]}"
  else
    echo "Search in which PM? (enter = all, or space-separated numbers e.g. 1 2)"
    local i=1
    local p
    for p in "${pms[@]}"; do echo "  $i) $p"; i=$((i+1)); done
    printf "Choice [default=all]: "
    read -r choice
    choice="${choice:-all}"
    if [ "$choice" = "all" ]; then
      _run_search_pms "$term" "${pms[@]}"
    else
      local selected=()
      local chosen_nums
      read -ra chosen_nums <<< "$choice"
      local n
      for n in "${chosen_nums[@]}"; do
        if [[ "$n" =~ ^[0-9]+$ ]] && [ "$n" -ge 1 ] && [ "$n" -le "${#pms[@]}" ]; then
          selected+=("${pms[$((n-1))]}")
        fi
      done
      if [ ${#selected[@]} -eq 0 ]; then
        log_error "No valid choice; searching all."
        _run_search_pms "$term" "${pms[@]}"
      else
        _run_search_pms "$term" "${selected[@]}"
      fi
    fi
  fi
}

run_sync() {
  require_initialized
  log_header "Sync: capture system state into declarative config"

  local tmp
  tmp=$(mktemp)
  local pm
  for pm in $(detect_available_pms); do
    pm_list_installed "$pm" 2>/dev/null | while IFS= read -r pkg; do
      [ -n "$pkg" ] && echo "$pm:$pkg" >> "$tmp"
    done || true
  done
  sort -u "$tmp" | grep -v '^$' > "${PACKAGES_CONF}.new" || true
  rm -f "$tmp"

  local atomic_tmp
  atomic_tmp=$(mktemp "${PACKAGES_CONF}.XXXXXX")
  {
    echo "# pdrx declarative packages"
    echo "# Format: package_manager:package_name  or  package_manager:package_name=version (pinned)"
    echo "#"
    echo "# ADD:     pdrx install <pkg>          records PM used"
    echo "# ADD PIN: pdrx install --pin <pkg>    records PM and version (optional --pin=VERSION)"
    echo "# REMOVE:  pdrx remove <pkg>           uses the recorded PM, removes from config"
    echo "# RESTORE: pdrx apply                  installs all packages using their recorded PM"
    echo "#"
    echo "# Synced: $(date_iso_seconds)"
    echo "# OS: $(detect_os_id)"
    echo ""
    cat "${PACKAGES_CONF}.new"
  } > "$atomic_tmp"
  mv "$atomic_tmp" "$PACKAGES_CONF"
  rm -f "${PACKAGES_CONF}.new"

  run_sync_systemd 2>/dev/null || true
  run_sync_desktop 2>/dev/null || true
  log_action "sync" "" "" "ok"
  log_success "Synced packages, sources, systemd units, and desktop state"
}

run_apply() {
  require_initialized
  log_header "Apply: reproduce declared system state"

  local PARALLEL=false
  while [ $# -gt 0 ]; do
    case "$1" in
      --parallel) PARALLEL=true; shift ;;
      *) shift ;;
    esac
  done

  # Sources MUST be wired up before package install, or packages outside
  # default distro repos (docker-ce, PPAs, COPRs, flathub apps) fail to
  # resolve on a genuinely fresh machine.
  _apply_sources 2>/dev/null || true

  if [ "$PARALLEL" = "true" ]; then
    _run_apply_parallel
  else
    _run_apply_sequential
  fi

  if [ -f "$TRACKED_DOTFILES" ]; then
    local rel
    while IFS= read -r rel; do
      [ -z "$rel" ] && continue
      local src="$DOTFILES_DIR/$rel"
      local dest="$HOME/$rel"
      if [ -f "$src" ]; then
        mkdir -p "$(dirname "$dest")"
        if [ "${DRY_RUN:-false}" = "true" ]; then
          log_info "[dry-run] would deploy dotfile: $rel"
        else
          cp "$src" "$dest"
          log_info "Deployed dotfile: $rel"
        fi
      fi
    done < "$TRACKED_DOTFILES"
  fi

  run_restore_desktop 2>/dev/null || true
  run_apply_systemd 2>/dev/null || true
  run_apply_hooks
  log_action "apply" "" "" "ok" "${PARALLEL:+parallel}"
}

_run_apply_sequential() {
  local count=0
  local line
  while IFS= read -r line; do
    if [[ "$line" == \#* ]] || [ -z "$line" ]; then
      continue
    fi
    _parse_conf_line "$line"
    local pm="$PARSED_PM" pkg="$PARSED_PKG" version="$PARSED_VERSION"
    if [ -z "$pm" ] || [ -z "$pkg" ]; then
      continue
    fi
    if pm_available "$pm" && ! pm_is_installed "$pm" "$pkg" 2>/dev/null; then
      if [ "${DRY_RUN:-false}" = "true" ]; then
        local label="$pm:$pkg"
        [ -n "$version" ] && label="$pm:$pkg=$version"
        log_info "[dry-run] would install: $label"
      else
        log_info "Installing $pkg via $pm${version:+ (=$version)}"
        if pm_install "$pm" "$pkg" "$version"; then
          count=$((count+1))
          log_action "apply_install" "$pm" "$pkg" "ok"
        else
          log_action "apply_install" "$pm" "$pkg" "failed"
        fi
      fi
    fi
  done < "$PACKAGES_CONF"
  log_success "Applied: installed $count new package(s)"
}

_run_apply_parallel() {
  declare -A PM_PKGS
  local pm_group_count=0
  local line
  while IFS= read -r line; do
    if [[ "$line" == \#* ]] || [ -z "$line" ]; then
      continue
    fi
    _parse_conf_line "$line"
    local pm="$PARSED_PM" pkg="$PARSED_PKG" version="$PARSED_VERSION"
    if [ -z "$pm" ] || [ -z "$pkg" ]; then
      continue
    fi
    if pm_available "$pm" && ! pm_is_installed "$pm" "$pkg" 2>/dev/null; then
      local entry="$pkg"
      [ -n "$version" ] && entry="${pkg}=${version}"
      if [ -z "${PM_PKGS[$pm]:-}" ]; then
        pm_group_count=$((pm_group_count + 1))
      fi
      PM_PKGS["$pm"]="${PM_PKGS[$pm]:-} $entry"
    fi
  done < "$PACKAGES_CONF"

  if [ "$pm_group_count" -eq 0 ]; then
    log_success "Apply (parallel): nothing to install — all packages already present"
    return 0
  fi

  log_header "Apply (parallel): installation plan"
  local pm
  for pm in $(echo "${!PM_PKGS[@]}" | tr ' ' '\n' | sort); do
    local entries count label
    read -ra entries <<< "${PM_PKGS[$pm]}"
    count="${#entries[@]}"
    label=$(printf '%s  ' "${entries[@]}")
    printf "  %s%-10s%s %d package(s): %s\n" \
      "${BOLD}${CYAN}" "[$pm]" "${NC}" "$count" "$label"
  done
  echo ""

  local lockfile
  lockfile=$(mktemp)

  local pids=()
  for pm in "${!PM_PKGS[@]}"; do
    (
      local pm_ok=0 pm_fail=0
      local entry

      _plog_info()    { flock "$lockfile" echo "${BLUE}[INFO]${NC}    ${CYAN}[$pm]${NC} $*"; }
      _plog_ok()      { flock "$lockfile" echo "${GREEN}[OK]${NC}      ${CYAN}[$pm]${NC} $*"; }
      _plog_warn()    { flock "$lockfile" echo "${YELLOW}[WARNING]${NC} ${CYAN}[$pm]${NC} $*"; }
      _plog_err()     { flock "$lockfile" echo "${RED}[ERROR]${NC}   ${CYAN}[$pm]${NC} $*"; }
      _plog_output()  { flock "$lockfile" echo "            ${CYAN}[$pm]${NC} $*"; }

      _plog_info "starting — $(echo "${PM_PKGS[$pm]}" | wc -w) package(s) queued"

      for entry in ${PM_PKGS[$pm]}; do
        local epkg="${entry%%=*}"
        local eversion=""
        [[ "$entry" == *=* ]] && eversion="${entry#*=}"

        if [ "${DRY_RUN:-false}" = "true" ]; then
          _plog_info "[dry-run] would install: $epkg${eversion:+ (=$eversion)}"
          continue
        fi

        _plog_info "installing $epkg${eversion:+ (=$eversion)}..."

        pm_install "$pm" "$epkg" "$eversion" 2>&1 \
          | while IFS= read -r pmline; do
              _plog_output "$pmline"
            done || true
        local install_rc="${PIPESTATUS[0]}"

        if [ "$install_rc" -eq 0 ]; then
          _plog_ok "$epkg installed successfully"
          pm_ok=$((pm_ok + 1))
          log_action "apply_install" "$pm" "$epkg" "ok"
        else
          _plog_err "failed to install $epkg (exit $install_rc)"
          pm_fail=$((pm_fail + 1))
          log_action "apply_install" "$pm" "$epkg" "failed"
        fi
      done

      if [ "$pm_fail" -eq 0 ]; then
        _plog_ok "group complete — $pm_ok installed, 0 failed"
      else
        _plog_warn "group complete — $pm_ok installed, $pm_fail failed"
      fi

      [ "$pm_fail" -gt 0 ] && exit 1 || exit 0
    ) &
    pids+=($!)
  done

  local failed=0
  local pid
  for pid in "${pids[@]}"; do
    wait "$pid" || failed=$((failed + 1))
  done
  # FIX (1.7.0): explicit cleanup right after wait drains, instead of relying
  # solely on a function-local RETURN trap (which could race a background
  # subshell still holding the flock).
  rm -f "$lockfile"

  echo ""
  if [ "$failed" -gt 0 ]; then
    log_warning "Apply (parallel): $failed PM group(s) had failures — review [ERROR] lines above"
  else
    log_success "Apply (parallel): all groups complete"
  fi
}

run_sync_desktop() {
  require_initialized
  export_desktop_state
  log_success "Exported desktop state to $DESKTOP_EXPORT"
}

run_restore_desktop() {
  require_initialized
  restore_desktop_state
  log_success "Restored desktop state from $DESKTOP_EXPORT"
}

run_track() {
  require_initialized
  local f
  for f in "$@"; do
    local abs
    abs=$(cd "$(dirname "$f")" 2>/dev/null && pwd)/$(basename "$f")
    [ -f "$abs" ] || abs="$HOME/$f"
    if [ ! -f "$abs" ]; then
      log_error "File not found: $f"
      continue
    fi
    local rel="${abs#"$HOME"/}"
    local dest="$DOTFILES_DIR/$rel"
    mkdir -p "$(dirname "$dest")"
    cp "$abs" "$dest"
    grep -qFx "$rel" "$TRACKED_DOTFILES" 2>/dev/null || echo "$rel" >> "$TRACKED_DOTFILES"
    ln -sf "$dest" "$abs" 2>/dev/null || true
    log_success "Tracking $rel"
  done
}

run_untrack() {
  require_initialized
  local f
  for f in "$@"; do
    local rel="${f#"$HOME"/}"
    [[ "$rel" == "$f" ]] && rel="$f"
    if [ -f "$TRACKED_DOTFILES" ]; then
      local tmp
      tmp=$(mktemp "${TRACKED_DOTFILES}.XXXXXX")
      grep -vFx "$rel" "$TRACKED_DOTFILES" > "$tmp" || true
      mv "$tmp" "$TRACKED_DOTFILES"
    fi
    local dest="$DOTFILES_DIR/$rel"
    [ -f "$dest" ] && rm -f "$dest"
    log_success "Untracked $rel"
  done
}

run_backup() {
  require_initialized
  local label="${1:-manual}"
  local ts
  ts=$(date +%Y%m%d_%H%M%S)
  local dir="$PDRX_BACKUP/${ts}_${label}"
  mkdir -p "$dir"
  cp "$PACKAGES_CONF" "$dir/packages.conf"
  [ -f "$SOURCES_CONF" ] && cp "$SOURCES_CONF" "$dir/sources.conf"
  [ -f "$SYSTEMD_CONF" ] && cp "$SYSTEMD_CONF" "$dir/systemd.conf"
  [ -d "$DESKTOP_EXPORT" ] && cp -R "$DESKTOP_EXPORT" "$dir/desktop-export"
  [ -d "$DOTFILES_DIR" ]   && cp -R "$DOTFILES_DIR"   "$dir/dotfiles"
  [ -d "$HOOKS_DIR" ]      && cp -R "$HOOKS_DIR"      "$dir/hooks"
  [ -f "$TRACKED_DOTFILES" ] && cp "$TRACKED_DOTFILES" "$dir/tracked-dotfiles"
  echo "$ts" >> "$GENERATIONS_FILE"
  log_action "backup" "" "" "ok" "$label"
  log_success "Backup: $dir"
}

run_restore() {
  require_initialized
  local path="$1"
  [ -z "$path" ] && { log_error "Usage: pdrx restore <backup-path>"; exit 1; }
  [ ! -d "$path" ] && { log_error "Not found: $path"; exit 1; }

  if [ "${DRY_RUN:-false}" = "true" ]; then
    log_info "[dry-run] would restore from $path"
    return 0
  fi
  if [ "${YES:-false}" != "true" ]; then
    printf "Restore from %s? [y/N]: " "$path"
    local r
    read -r r
    [[ "$r" =~ ^[Yy]$ ]] || return 0
  fi

  [ -f "$path/packages.conf" ]    && cp "$path/packages.conf" "$PACKAGES_CONF"
  [ -f "$path/sources.conf" ]     && cp "$path/sources.conf" "$SOURCES_CONF"
  [ -f "$path/systemd.conf" ]     && cp "$path/systemd.conf" "$SYSTEMD_CONF"
  [ -d "$path/desktop-export" ]   && rm -rf "$DESKTOP_EXPORT" && cp -R "$path/desktop-export" "$DESKTOP_EXPORT"
  [ -d "$path/dotfiles" ]         && rm -rf "$DOTFILES_DIR"   && cp -R "$path/dotfiles" "$DOTFILES_DIR"
  [ -d "$path/hooks" ]            && rm -rf "$HOOKS_DIR"      && cp -R "$path/hooks" "$HOOKS_DIR"
  [ -f "$path/tracked-dotfiles" ] && cp "$path/tracked-dotfiles" "$TRACKED_DOTFILES"
  log_action "restore" "" "" "ok" "$path"
  log_success "Restored from $path"
}

_list_backup_dirs_oldest_first() {
  [ ! -d "$PDRX_BACKUP" ] && return 0
  # shellcheck disable=SC2012
  ls -1 "$PDRX_BACKUP" 2>/dev/null | while IFS= read -r d; do
    [ -n "$d" ] && [ -d "$PDRX_BACKUP/$d" ] && echo "$d"
  done
}

run_generations() {
  require_initialized
  log_header "Generations (backups)"
  local ref=0
  local d
  while IFS= read -r d; do
    [ -z "$d" ] && continue
    ref=$((ref + 1))
    echo "  $ref) $PDRX_BACKUP/$d"
  done < <(_list_backup_dirs_oldest_first)
  if [ "$ref" -gt 0 ]; then
    echo "  ---"
    echo "  current  (active config, not a backup)"
  fi
  [ "$ref" -eq 0 ] && log_info "No backups yet."
  return 0
}

run_clean() {
  require_initialized
  local arg="${1:-}"
  log_debug "run_clean: arg='$arg'"

  if [ -z "$arg" ]; then
    log_header "Generations (oldest to newest); use 'pdrx clean <ref|range|all|current>' to remove"
    local ref=0
    local d
    while IFS= read -r d; do
      [ -z "$d" ] && continue
      ref=$((ref + 1))
      echo "  $ref) $PDRX_BACKUP/$d"
    done < <(_list_backup_dirs_oldest_first)
    if [ "$ref" -gt 0 ]; then
      echo "  ---"
      echo "  current  (active config, not a backup)"
      echo ""
      echo "Examples: pdrx clean 3-10  (remove refs 3 through 10)"
      echo "          pdrx clean all  (remove all backups)"
      echo "          pdrx clean current (remove newest backup only)"
    else
      log_info "No backups to clean."
    fi
    return 0
  fi

  local dirs=()
  local d
  while IFS= read -r d; do
    [ -n "$d" ] && [ -d "$PDRX_BACKUP/$d" ] && dirs+=("$d")
  done < <(_list_backup_dirs_oldest_first)
  local total=${#dirs[@]}

  if [ "$total" -eq 0 ]; then
    log_info "No backups to clean."
    return 0
  fi

  case "$arg" in
    all)
      if [ "${YES:-false}" != "true" ]; then
        printf "Remove ALL %d backup(s)? [y/N]: " "$total"
        local r
        read -r r
        [[ "$r" =~ ^[Yy]$ ]] || return 0
      fi
      local d
      for d in "${dirs[@]}"; do
        [ -z "$d" ] && continue
        rm -rf "${PDRX_BACKUP:?}/$d"
        log_success "Removed ${PDRX_BACKUP}/$d"
      done
      ;;
    current)
      [ "$total" -lt 1 ] && return 0
      local newest="${dirs[$((total - 1))]}"
      [ -z "$newest" ] && return 0
      if [ "${YES:-false}" != "true" ]; then
        printf "Remove newest backup '%s'? [y/N]: " "$newest"
        local r
        read -r r
        [[ "$r" =~ ^[Yy]$ ]] || return 0
      fi
      rm -rf "${PDRX_BACKUP:?}/$newest"
      log_success "Removed ${PDRX_BACKUP}/$newest"
      ;;
    *-*)
      local r1="${arg%-*}"
      local r2="${arg#*-}"
      local low=$((r1 < r2 ? r1 : r2))
      local high=$((r1 > r2 ? r1 : r2))
      if [ "$low" -lt 1 ] || [ "$high" -gt "$total" ]; then
        log_error "Range must be 1-$total"
        exit 1
      fi
      if [ "${YES:-false}" != "true" ]; then
        printf "Remove backups %d through %d? [y/N]: " "$low" "$high"
        local r
        read -r r
        [[ "$r" =~ ^[Yy]$ ]] || return 0
      fi
      local i
      for ((i = low; i <= high; i++)); do
        local idx=$((i - 1))
        local dname="${dirs[$idx]:-}"
        [ -n "$dname" ] && rm -rf "${PDRX_BACKUP:?}/$dname" && log_success "Removed ${PDRX_BACKUP}/$dname"
      done
      ;;
    *)
      if [[ "$arg" =~ ^[0-9]+$ ]]; then
        if [ "$arg" -lt 1 ] || [ "$arg" -gt "$total" ]; then
          log_error "Ref must be 1-$total"
          exit 1
        fi
        local idx=$((arg - 1))
        local dname="${dirs[$idx]}"
        [ -z "$dname" ] && return 0
        if [ "${YES:-false}" != "true" ]; then
          printf "Remove backup '%s'? [y/N]: " "$dname"
          local r
          read -r r
          [[ "$r" =~ ^[Yy]$ ]] || return 0
        fi
        rm -rf "${PDRX_BACKUP:?}/$dname"
        log_success "Removed ${PDRX_BACKUP}/$dname"
      else
        log_error "Usage: pdrx clean [all|current|<ref>|<ref1-ref2>]"
        exit 1
      fi
      ;;
  esac
}

run_rollback() {
  require_initialized
  local n="${1:-1}"
  local dirs=()
  local d
  while IFS= read -r d; do
    [ -n "$d" ] && dirs+=("$d")
  done < <(_list_backup_dirs_oldest_first)
  local total=${#dirs[@]}
  [ "$total" -eq 0 ] && { log_error "No backups found"; exit 1; }
  local idx=$(( total - n ))
  if [ "$idx" -lt 0 ]; then
    log_error "No backup #$n (only $total backup(s) exist)"
    exit 1
  fi
  run_restore "$PDRX_BACKUP/${dirs[$idx]}"
}

run_export() {
  require_initialized
  local out="${1:-}"
  if [ -n "$out" ]; then
    tar -czf "$out" -C "$PDRX_HOME" config state 2>/dev/null \
      || tar -czf "$out" -C "$PDRX_CONFIG" .
    log_success "Exported to $out"
  else
    tar -czf - -C "$PDRX_HOME" config state 2>/dev/null \
      || tar -czf - -C "$PDRX_CONFIG" .
  fi
}

run_import() {
  require_initialized
  local file="$1"
  [ -z "$file" ] && { log_error "Usage: pdrx import <file>"; exit 1; }
  [ ! -f "$file" ] && { log_error "Not found: $file"; exit 1; }
  tar -xzf "$file" -C "$PDRX_HOME" 2>/dev/null \
    || tar -xzf "$file" -C "$PDRX_CONFIG" 2>/dev/null
  log_success "Imported from $file"
}

run_update() {
  require_initialized
  local pm
  for pm in $(detect_available_pms); do
    log_info "Updating $pm index..."
    pm_update "$pm" 2>/dev/null || log_warning "Update failed for $pm"
  done
  log_success "Package indexes updated"
}

run_upgrade() {
  require_initialized
  local pm
  for pm in $(detect_available_pms); do
    log_info "Upgrading packages via $pm..."
    pm_upgrade "$pm" 2>/dev/null || log_warning "Upgrade failed for $pm"
  done
  log_success "Upgrade complete for all package managers"
}

run_destroy() {
  log_header "Destroy pdrx"
  echo "This will:"
  echo "  • Restore tracked dotfiles: replace symlinks with real files (content from pdrx copy)"
  echo "  • Remove $PDRX_HOME (config, backups, state)"
  echo "  • Remove pdrx from ~/.local/bin"
  echo ""
  echo "Installed packages, added repo sources, and enabled systemd units will NOT be reverted."
  echo ""
  if [ "${YES:-false}" != "true" ]; then
    printf "Type 'yes' to continue: "
    local r
    read -r r
    [ "$r" != "yes" ] && return 0
  fi

  if [ -f "$TRACKED_DOTFILES" ]; then
    local rel
    while IFS= read -r rel; do
      [ -z "$rel" ] && continue
      local dest="$HOME/$rel"
      local src="$DOTFILES_DIR/$rel"
      if [ -L "$dest" ]; then
        rm -f "$dest"
        if [ -f "$src" ]; then
          mkdir -p "$(dirname "$dest")"
          cp "$src" "$dest"
          log_success "Restored $rel (symlink replaced with real file)"
        else
          log_warning "Removed symlink $rel (pdrx copy missing)"
        fi
      fi
    done < "$TRACKED_DOTFILES"
  fi

  rm -rf "$PDRX_HOME"
  [ -f "$HOME/.local/bin/pdrx" ] && rm -f "$HOME/.local/bin/pdrx"
  local rc
  for rc in "$HOME/.bashrc" "$HOME/.zshrc"; do
    if [ -f "$rc" ]; then
      # shellcheck disable=SC2016
      grep -v -F '# Added by pdrx' "$rc" \
        | grep -v -F 'export PATH="$PATH:$HOME/.local/bin"' \
        > "${rc}.tmp" 2>/dev/null && mv "${rc}.tmp" "$rc"
    fi
  done
  log_success "pdrx destroyed. Dotfiles restored to real files; symlinks removed."
}

run_install_self() {
  log_header "Install pdrx"
  local install_dir="$HOME/.local/bin"
  local self
  self="$(get_script_path)"
  [ -f "$self" ] || self="$(cd "$(dirname "$0")" && pwd)/pdrx"
  mkdir -p "$install_dir"
  cp "$self" "$install_dir/pdrx"
  chmod +x "$install_dir/pdrx"
  # shellcheck disable=SC2016
  local path_line='export PATH="$PATH:$HOME/.local/bin"'
  local rc
  for rc in "$HOME/.bashrc" "$HOME/.zshrc"; do
    if [ -f "$rc" ]; then
      if ! grep -q '\.local/bin' "$rc"; then
        printf '\n# Added by pdrx\n%s\n' "$path_line" >> "$rc"
      fi
    fi
  done
  log_success "Installed to $install_dir/pdrx. Run: source ~/.bashrc && pdrx init"
}

# =============================================================================
# SELF-UPDATE  (hardened in 1.7.0)
# =============================================================================
#
# FIX (1.7.0): previously curled a raw script from GitHub and chmod +x/
# replaced the running binary with ZERO integrity verification — anyone able
# to MITM the connection or briefly compromise the repo/CDN got arbitrary
# code execution on every machine that ran `pdrx self-update`. This now:
#   1. Pins to a tagged release asset instead of the mutable `main` branch.
#   2. Downloads the accompanying .sha256 checksum file published in the
#      same release and verifies the script against it before replacing
#      the installed binary.
#   3. Refuses to proceed (rather than silently trusting) if the checksum
#      file is missing or doesn't match.
#
# NOTE: this requires the pdrx release process to publish `pdrx` and
# `pdrx.sha256` (or a combined SHA256SUMS file) as GitHub release assets —
# see the PR description for the accompanying release workflow change.

run_self_update() {
  log_header "Self-update pdrx"
  local install_path
  install_path="$(get_script_path)"

  if ! command -v curl >/dev/null 2>&1 && ! command -v wget >/dev/null 2>&1; then
    log_error "curl or wget is required for self-update"
    exit 1
  fi
  if ! command -v sha256sum >/dev/null 2>&1; then
    log_error "sha256sum is required for self-update (integrity verification)"
    exit 1
  fi

  log_info "Checking latest release..."
  local api_url="https://api.github.com/repos/stefan-hacks/pdrx/releases/latest"
  local rel_json
  rel_json=$(_fetch_url "$api_url") || { log_error "Failed to query latest release"; exit 1; }

  local tag
  tag=$(printf '%s' "$rel_json" | grep -m1 '"tag_name"' | sed -E 's/.*"tag_name": *"([^"]+)".*/\1/')
  [ -z "$tag" ] && { log_error "Could not determine latest release tag"; exit 1; }

  local remote_version="${tag#v}"
  if [ "$remote_version" = "$VERSION" ]; then
    log_info "Already up to date (v$VERSION)"
    return 0
  fi

  local script_url="https://github.com/stefan-hacks/pdrx/releases/download/${tag}/pdrx"
  local sum_url="https://github.com/stefan-hacks/pdrx/releases/download/${tag}/pdrx.sha256"

  local tmp tmp_sum
  tmp=$(mktemp)
  tmp_sum=$(mktemp)
  _fetch_to_file "$script_url" "$tmp" || { log_error "Failed to download pdrx $tag"; rm -f "$tmp" "$tmp_sum"; exit 1; }
  if ! _fetch_to_file "$sum_url" "$tmp_sum"; then
    log_error "Could not download checksum file (pdrx.sha256) for $tag — refusing to install unverified update."
    log_error "This is a hard stop: self-update never replaces the binary without a verified checksum."
    rm -f "$tmp" "$tmp_sum"
    exit 1
  fi

  local expected actual
  expected=$(awk '{print $1}' "$tmp_sum" | head -1)
  actual=$(sha256sum "$tmp" | awk '{print $1}')
  if [ -z "$expected" ] || [ "$expected" != "$actual" ]; then
    log_error "Checksum verification FAILED for $tag."
    log_error "  expected: ${expected:-<empty>}"
    log_error "  actual:   $actual"
    log_error "Not installing. This could mean a corrupted download or a tampered release — investigate before retrying."
    rm -f "$tmp" "$tmp_sum"
    exit 1
  fi

  log_success "Checksum verified ($actual)"
  log_info "Updating $VERSION → $remote_version"
  chmod +x "$tmp"
  mv "$tmp" "$install_path"
  rm -f "$tmp_sum"
  log_action "self_update" "" "" "ok" "$VERSION->$remote_version"
  log_success "Updated pdrx to v$remote_version. Re-run pdrx to use the new version."
}

_fetch_url() {
  local url="$1"
  if command -v curl >/dev/null 2>&1; then
    curl -fsSL -H "Accept: application/vnd.github+json" "$url"
  else
    wget -qO- "$url"
  fi
}

_fetch_to_file() {
  local url="$1" dest="$2"
  if command -v curl >/dev/null 2>&1; then
    curl -fsSL "$url" -o "$dest"
  else
    wget -qO "$dest" "$url"
  fi
}

