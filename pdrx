run_sync_dotfiles() {
  require_initialized
  log_header "Sync: auto-discover and track common dotfiles"

  # Common dotfiles to auto-discover
  local common_dotfiles=(
    # Shell configs
    ".bashrc"
    ".bash_profile"
    ".bash_login"
    ".bash_logout"
    ".zshrc"
    ".zprofile"
    ".zshenv"
    ".zlogin"
    ".zlogout"
    ".config/fish/config.fish"
    ".config/fish/fish_variables"
    ".config/nushell/config.nu"
    ".config/nushell/env.nu"
    ".config/nushell/history.txt"
    # Vim/Neovim
    ".vimrc"
    ".vim/vimrc"
    ".config/nvim/init.vim"
    ".config/nvim/init.lua"
    ".config/nvim/coc-settings.json"
    # Tmux
    ".tmux.conf"
    ".config/tmux/tmux.conf"
    # Git
    ".gitconfig"
    ".config/git/config"
    ".config/git/ignore"
    # SSH
    ".ssh/config"
    # Kitty
    ".config/kitty/kitty.conf"
    ".config/kitty/theme.conf"
    # Alacritty
    ".config/alacritty/alacritty.yml"
    ".config/alacritty/alacritty.toml"
    # WezTerm
    ".config/wezterm/wezterm.lua"
    ".wezterm.lua"
    # VS Code
    ".config/Code/User/settings.json"
    ".config/Code/User/keybindings.json"
    # Helix
    ".config/helix/config.toml"
    # Emacs
    ".emacs"
    ".emacs.d/init.el"
    ".config/emacs/init.el"
    # Starship
    ".config/starship.toml"
    # Direnv
    ".config/direnv/direnvrc"
    # ASDF
    ".tool-versions"
    # Nix
    ".config/nix/nix.conf"
    ".config/nixpkgs/config.nix"
    # GPG
    ".gnupg/gpg.conf"
    ".gnupg/gpg-agent.conf"
    # Curl/Wget
    ".curlrc"
    ".wgetrc"
    # Less
    ".lesskey"
    # Inputrc
    ".inputrc"
    # Editorconfig
    ".editorconfig"
    # Wgetrc
    ".wgetrc"
    # X11/Wayland
    ".Xresources"
    ".Xmodmap"
    ".xinitrc"
    ".config/user-dirs.dirs"
    # Misc
    ".profile"
    ".hushlogin"
  )

  local found=0
  local tracked=0
  local skipped=0

  for file in "${common_dotfiles[@]}"; do
    local path="$HOME/$file"
    if [ -f "$path" ]; then
      found=$((found + 1))
      local rel="$file"
      
      # Check if already tracked
      if [ -f "$TRACKED_DOTFILES" ] && grep -qFx "$rel" "$TRACKED_DOTFILES" 2>/dev/null; then
        log_info "Already tracked: $rel"
        skipped=$((skipped + 1))
        continue
      fi

      # Track it
      local dest="$DOTFILES_DIR/$rel"
      mkdir -p "$(dirname "$dest")"
      cp "$path" "$dest"
      grep -qFx "$rel" "$TRACKED_DOTFILES" 2>/dev/null || echo "$rel" >> "$TRACKED_DOTFILES"
      ln -sf "$dest" "$path" 2>/dev/null || true
      log_success "Tracked: $rel"
      tracked=$((tracked + 1))
    fi
  done

  # Also check .config directories that are commonly tracked
  local common_configs=(
    "nvim"
    "kitty"
    "tmux"
    "fish"
    "nushell"
    "alacritty"
    "wezterm"
    "helix"
    "git"
    "starship"
    "direnv"
  )

  for config_dir in "${common_configs[@]}"; do
    local config_path="$HOME/.config/$config_dir"
    if [ -d "$config_path" ] && [ ! -L "$config_path" ]; then
      # Check if any files in this directory are already tracked individually
      local has_tracked=false
      if [ -f "$TRACKED_DOTFILES" ]; then
        while IFS= read -r tracked_file; do
          if [[ "$tracked_file" == ".config/$config_dir/"* ]]; then
            has_tracked=true
            break
          fi
        done < "$TRACKED_DOTFILES"
      fi

      if [ "$has_tracked" = false ] && [ ! -d "$DOTFILES_DIR/.config/$config_dir" ]; then
        log_info "Found config directory (not auto-tracked, use 'pdrx track ~/.config/$config_dir' to track entire dir): $config_dir"
      fi
    fi
  done

  log_success "Dotfile sync complete: $found found, $tracked newly tracked, $skipped already tracked"
}

run_track() {
  require_initialized
  local f
  for f in "$@"; do
    local abs
    # Path resolution priority:
    # 1. If absolute path (starts with /), use it
    # 2. If exists in current directory, use relative to PWD (for shell glob like *)
    # 3. Otherwise, resolve relative to $HOME
    if [[ "$f" == /* ]]; then
      abs="$f"
    elif [ -e "$PWD/$f" ]; then
      abs="$PWD/$f"
    else
      abs="$HOME/$f"
    fi

    # pdrx's dotfile tracking is fundamentally $HOME-relative (untrack, apply,
    # and destroy all deploy/restore via "$HOME/$rel"). Reject anything
    # outside $HOME up front instead of silently mis-tracking it.
    case "$abs" in
      "$HOME"/*) : ;;
      *)
        log_warning "Skipping $f: outside \$HOME is not supported by pdrx tracking"
        continue
        ;;
    esac

    # Handle directory tracking
    if [ -d "$abs" ]; then
      log_info "Tracking directory: $abs"
      local tracked_count=0
      while IFS= read -r -d '' file_in_dir; do
        local rel="${file_in_dir#"$HOME"/}"
        local dest="$DOTFILES_DIR/$rel"
        mkdir -p "$(dirname "$dest")"
        cp "$file_in_dir" "$dest"
        grep -qFx "$rel" "$TRACKED_DOTFILES" 2>/dev/null || echo "$rel" >> "$TRACKED_DOTFILES"
        ln -sf "$dest" "$file_in_dir" 2>/dev/null || true
        tracked_count=$((tracked_count + 1))
      done < <(find "$abs" -type f -print0 2>/dev/null)
      log_success "Tracked $tracked_count files from directory $f"
      continue
    fi

    # Handle file tracking (original logic)
    if [ ! -f "$abs" ]; then
      log_error "File not found: $f"
      continue
    fi
    local rel="${abs#"$HOME"/}"
    local dest="$DOTFILES_DIR/$rel"
    mkdir -p "$(dirname "$dest")"
    cp "$abs" "$dest"
    grep -qFx "$rel" "$TRACKED_DOTFILES" 2>/dev/null || echo "$rel" >> "$TRACKED_DOTFILES"
    ln -sf "$dest" "$abs" 2>/dev/null || true
    log_success "Tracking $rel"
  done
}

run_untrack() {
  require_initialized
  local f
  for f in "$@"; do
    local abs
    # Path resolution priority (same as run_track):
    # 1. If absolute path (starts with /), use it
    # 2. If exists in current directory, use relative to PWD
    # 3. Otherwise, resolve relative to $HOME
    if [[ "$f" == /* ]]; then
      abs="$f"
    elif [ -e "$PWD/$f" ]; then
      abs="$PWD/$f"
    else
      abs="$HOME/$f"
    fi

    # Handle directory untracking
    if [ -d "$abs" ]; then
      log_info "Untracking directory: $abs"
      local untracked_count=0
      # Get the directory path relative to HOME
      local dir_rel="${abs#"$HOME"/}"
      # Ensure dir_rel ends with / for proper matching
      [[ "$dir_rel" == */ ]] || dir_rel="$dir_rel/"
      
      # Get all tracked files that are within this directory. Read the full
      # list into memory first so we never read-and-rewrite $TRACKED_DOTFILES
      # from inside the same loop that's iterating over it.
      if [ -f "$TRACKED_DOTFILES" ]; then
        local -a matched=()
        local tracked_file
        while IFS= read -r tracked_file; do
          [ -z "$tracked_file" ] && continue
          # Match: starts with "dir_rel" and has content after it
          if [[ "$tracked_file" == "$dir_rel"* ]] && [ "${#tracked_file}" -gt "${#dir_rel}" ]; then
            matched+=("$tracked_file")
          fi
        done < "$TRACKED_DOTFILES"

        for tracked_file in "${matched[@]}"; do
          local target="$HOME/$tracked_file"
          local dest="$DOTFILES_DIR/$tracked_file"

          if [ "${DRY_RUN:-false}" = "true" ]; then
            log_info "[dry-run] would untrack $tracked_file from within directory $f"
            continue
          fi

          # Restore file if it's a symlink
          if [ -L "$target" ]; then
            rm -f "$target"
            if [ -f "$dest" ]; then
              mkdir -p "$(dirname "$target")"
              cp "$dest" "$target"
              log_success "Restored $tracked_file (symlink replaced with real file)"
            else
              log_warning "Removed dangling symlink at $tracked_file"
            fi
          elif [ -e "$target" ] && [ -f "$dest" ]; then
            # Target exists but isn't a symlink - still try to restore
            cp -f "$dest" "$target"
            log_success "Restored $tracked_file (overwrote existing)"
          elif [ -f "$dest" ]; then
            # Target missing, restore from backup
            mkdir -p "$(dirname "$target")"
            cp "$dest" "$target"
            log_success "Restored $tracked_file (was missing)"
          fi

          # Remove the stored copy
          [ -f "$dest" ] && rm -f "$dest"
          # Clean up empty directories
          [ -d "$(dirname "$dest")" ] && rmdir -p "$(dirname "$dest")" 2>/dev/null || true

          log_action "untrack" "" "$tracked_file" "ok"
          untracked_count=$((untracked_count + 1))
        done

        # Rewrite tracked-dotfiles once, after iteration is complete
        if [ "${DRY_RUN:-false}" != "true" ] && [ "${#matched[@]}" -gt 0 ]; then
          local tmp
          tmp=$(mktemp "${TRACKED_DOTFILES}.XXXXXX")
          cp "$TRACKED_DOTFILES" "$tmp"
          for tracked_file in "${matched[@]}"; do
            grep -vFx "$tracked_file" "$tmp" > "${tmp}.next" || true
            mv "${tmp}.next" "$tmp"
          done
          mv "$tmp" "$TRACKED_DOTFILES"
        fi
      fi
      log_success "Untracked $untracked_count files from directory $f"
      continue
    fi

    # Single file untracking (original logic)
    local rel
    # Resolve to a path relative to $HOME, using the same convention
    # tracked-dotfiles stores paths in (mirrors run_track's resolution):
    case "$f" in
      "$HOME"/*) rel="${f#"$HOME"/}" ;;
      /*)
        log_warning "Skipping $f: absolute path outside \$HOME is not tracked by pdrx"
        continue
        ;;
      *) rel="$f" ;;
    esac

    if [ -f "$TRACKED_DOTFILES" ] && ! grep -qFx "$rel" "$TRACKED_DOTFILES" 2>/dev/null; then
      log_warning "$rel is not currently tracked (nothing to do)"
      continue
    fi

    local dest="$DOTFILES_DIR/$rel"
    local target="$HOME/$rel"

    # FIX (critical, 1.8.0): previously this function deleted the
    # pdrx-owned copy in $DOTFILES_DIR and never touched $target — since
    # $target is a symlink pointing at that copy (created by `pdrx track`),
    # the result was a dangling symlink and the file's content was gone.
    # Untrack must do the inverse of track: put a REAL file back at the
    # original location and remove the symlink, before any copies are
    # deleted.
    if [ "${DRY_RUN:-false}" = "true" ]; then
      log_info "[dry-run] would untrack $rel: restore real file to $target, remove symlink, drop pdrx copy"
      continue
    fi

    if [ -L "$target" ]; then
      rm -f "$target"
      if [ -f "$dest" ]; then
        mkdir -p "$(dirname "$target")"
        cp "$dest" "$target"
        log_success "Restored $rel to $target (symlink replaced with real file)"
      else
        log_warning "Removed dangling symlink at $rel (pdrx copy was already missing — content could not be restored)"
      fi
    elif [ -e "$target" ]; then
      # Target exists but isn't a pdrx symlink (e.g. user already replaced
      # it manually) — don't clobber whatever is there now.
      log_info "$rel at \$HOME is not a pdrx symlink; leaving it as-is"
    else
      # Target missing entirely but we still have the pdrx copy: restore it.
      if [ -f "$dest" ]; then
        mkdir -p "$(dirname "$target")"
        cp "$dest" "$target"
        log_success "Restored $rel to $target (was missing from \$HOME)"
      fi
    fi

    [ -f "$dest" ] && rm -f "$dest"
    # Clean up empty directories in DOTFILES_DIR
    [ -d "$(dirname "$dest")" ] && rmdir -p "$(dirname "$dest")" 2>/dev/null || true

    if [ -f "$TRACKED_DOTFILES" ]; then
      local tmp
      tmp=$(mktemp "${TRACKED_DOTFILES}.XXXXXX")
      grep -vFx "$rel" "$TRACKED_DOTFILES" > "$tmp" || true
      mv "$tmp" "$TRACKED_DOTFILES"
    fi

    log_action "untrack" "" "$rel" "ok"
    log_success "Untracked $rel"
  done
}

run_backup() {
  require_initialized
  local label="${1:-manual}"
  local ts
  ts=$(date +%Y%m%d_%H%M%S)
  local dir="$PDRX_BACKUP/${ts}_${label}"
  mkdir -p "$dir"
  cp "$PACKAGES_CONF" "$dir/packages.conf"
  [ -f "$SOURCES_CONF" ] && cp "$SOURCES_CONF" "$dir/sources.conf"
  [ -f "$SYSTEMD_CONF" ] && cp "$SYSTEMD_CONF" "$dir/systemd.conf"
  [ -d "$DESKTOP_EXPORT" ] && cp -R "$DESKTOP_EXPORT" "$dir/desktop-export"
  [ -d "$DOTFILES_DIR" ]   && cp -R "$DOTFILES_DIR"   "$dir/dotfiles"
  [ -d "$HOOKS_DIR" ]      && cp -R "$HOOKS_DIR"      "$dir/hooks"
  [ -f "$TRACKED_DOTFILES" ] && cp "$TRACKED_DOTFILES" "$dir/tracked-dotfiles"
  echo "$ts" >> "$GENERATIONS_FILE"
  log_action "backup" "" "" "ok" "$label"
  log_success "Backup: $dir"
}

run_restore() {
  require_initialized
  local path="$1"
  [ -z "$path" ] && { log_error "Usage: pdrx restore <backup-path>"; exit 1; }
  [ ! -d "$path" ] && { log_error "Not found: $path"; exit 1; }

  if [ "${DRY_RUN:-false}" = "true" ]; then
    log_info "[dry-run] would restore from $path"
    return 0
  fi
  if [ "${YES:-false}" != "true" ]; then
    printf "Restore from %s? [y/N]: " "$path"
    local r
    read -r r
    [[ "$r" =~ ^[Yy]$ ]] || return 0
  fi

  [ -f "$path/packages.conf" ]    && cp "$path/packages.conf" "$PACKAGES_CONF"
  [ -f "$path/sources.conf" ]     && cp "$path/sources.conf" "$SOURCES_CONF"
  [ -f "$path/systemd.conf" ]     && cp "$path/systemd.conf" "$SYSTEMD_CONF"
  [ -d "$path/desktop-export" ]   && rm -rf "$DESKTOP_EXPORT" && cp -R "$path/desktop-export" "$DESKTOP_EXPORT"
  [ -d "$path/dotfiles" ]         && rm -rf "$DOTFILES_DIR"   && cp -R "$path/dotfiles" "$DOTFILES_DIR"
  [ -d "$path/hooks" ]            && rm -rf "$HOOKS_DIR"      && cp -R "$path/hooks" "$HOOKS_DIR"
  [ -f "$path/tracked-dotfiles" ] && cp "$path/tracked-dotfiles" "$TRACKED_DOTFILES"
  log_action "restore" "" "" "ok" "$path"
  log_success "Restored from $path"
}

_list_backup_dirs_oldest_first() {
  [ ! -d "$PDRX_BACKUP" ] && return 0
  # shellcheck disable=SC2012
  ls -1 "$PDRX_BACKUP" 2>/dev/null | while IFS= read -r d; do
    [ -n "$d" ] && [ -d "$PDRX_BACKUP/$d" ] && echo "$d"
  done
}

run_generations() {
  require_initialized
  log_header "Generations (backups)"
  local ref=0
  local d
  while IFS= read -r d; do
    [ -z "$d" ] && continue
    ref=$((ref + 1))
    echo "  $ref) $PDRX_BACKUP/$d"
  done < <(_list_backup_dirs_oldest_first)
  if [ "$ref" -gt 0 ]; then
    echo "  ---"
    echo "  current  (active config, not a backup)"
  fi
  [ "$ref" -eq 0 ] && log_info "No backups yet."
  return 0
}

run_clean() {
  require_initialized
  local arg="${1:-}"
  log_debug "run_clean: arg='$arg'"

  if [ -z "$arg" ]; then
    log_header "Generations (oldest to newest); use 'pdrx clean <ref|range|all|current>' to remove"
    local ref=0
    local d
    while IFS= read -r d; do
      [ -z "$d" ] && continue
      ref=$((ref + 1))
      echo "  $ref) $PDRX_BACKUP/$d"
    done < <(_list_backup_dirs_oldest_first)
    if [ "$ref" -gt 0 ]; then
      echo "  ---"
      echo "  current  (active config, not a backup)"
      echo ""
      echo "Examples: pdrx clean 3-10  (remove refs 3 through 10)"
      echo "          pdrx clean all  (remove all backups)"
      echo "          pdrx clean current (remove newest backup only)"
    else
      log_info "No backups to clean."
    fi
    return 0
  fi

  local dirs=()
  local d
  while IFS= read -r d; do
    [ -n "$d" ] && [ -d "$PDRX_BACKUP/$d" ] && dirs+=("$d")
  done < <(_list_backup_dirs_oldest_first)
  local total=${#dirs[@]}

  if [ "$total" -eq 0 ]; then
    log_info "No backups to clean."
    return 0
  fi

  case "$arg" in
    all)
      if [ "${YES:-false}" != "true" ]; then
        printf "Remove ALL %d backup(s)? [y/N]: " "$total"
        local r
        read -r r
        [[ "$r" =~ ^[Yy]$ ]] || return 0
      fi
      local d
      for d in "${dirs[@]}"; do
        [ -z "$d" ] && continue
        rm -rf "${PDRX_BACKUP:?}/$d"
        log_success "Removed ${PDRX_BACKUP}/$d"
      done
      ;;
    current)
      [ "$total" -lt 1 ] && return 0
      local newest="${dirs[$((total - 1))]}"
      [ -z "$newest" ] && return 0
      if [ "${YES:-false}" != "true" ]; then
        printf "Remove newest backup '%s'? [y/N]: " "$newest"
        local r
        read -r r
        [[ "$r" =~ ^[Yy]$ ]] || return 0
      fi
      rm -rf "${PDRX_BACKUP:?}/$newest"
      log_success "Removed ${PDRX_BACKUP}/$newest"
      ;;
    *-*)
      local r1="${arg%-*}"
      local r2="${arg#*-}"
      local low=$((r1 < r2 ? r1 : r2))
      local high=$((r1 > r2 ? r1 : r2))
      if [ "$low" -lt 1 ] || [ "$high" -gt "$total" ]; then
        log_error "Range must be 1-$total"
        exit 1
      fi
      if [ "${YES:-false}" != "true" ]; then
        printf "Remove backups %d through %d? [y/N]: " "$low" "$high"
        local r
        read -r r
        [[ "$r" =~ ^[Yy]$ ]] || return 0
      fi
      local i
      for ((i = low; i <= high; i++)); do
        local idx=$((i - 1))
        local dname="${dirs[$idx]:-}"
        [ -n "$dname" ] && rm -rf "${PDRX_BACKUP:?}/$dname" && log_success "Removed ${PDRX_BACKUP}/$dname"
      done
      ;;
    *)
      if [[ "$arg" =~ ^[0-9]+$ ]]; then
        if [ "$arg" -lt 1 ] || [ "$arg" -gt "$total" ]; then
          log_error "Ref must be 1-$total"
          exit 1
        fi
        local idx=$((arg - 1))
        local dname="${dirs[$idx]}"
        [ -z "$dname" ] && return 0
        if [ "${YES:-false}" != "true" ]; then
          printf "Remove backup '%s'? [y/N]: " "$dname"
          local r
          read -r r
          [[ "$r" =~ ^[Yy]$ ]] || return 0
        fi
        rm -rf "${PDRX_BACKUP:?}/$dname"
        log_success "Removed ${PDRX_BACKUP}/$dname"
      else
        log_error "Usage: pdrx clean [all|current|<ref>|<ref1-ref2>]"
        exit 1
      fi
      ;;
  esac
}

run_rollback() {
  require_initialized
  local n="${1:-1}"
  local dirs=()
  local d
  while IFS= read -r d; do
    [ -n "$d" ] && dirs+=("$d")
  done < <(_list_backup_dirs_oldest_first)
  local total=${#dirs[@]}
  [ "$total" -eq 0 ] && { log_error "No backups found"; exit 1; }
  local idx=$(( total - n ))
  if [ "$idx" -lt 0 ]; then
    log_error "No backup #$n (only $total backup(s) exist)"
    exit 1
  fi
  run_restore "$PDRX_BACKUP/${dirs[$idx]}"
}

run_export() {
  require_initialized
  if [ "${1:-}" = "--ansible" ]; then
    shift
    run_export_ansible "$@"
    return
  fi
  local out="${1:-}"
  if [ -n "$out" ]; then
    tar -czf "$out" -C "$PDRX_HOME" config state 2>/dev/null \
      || tar -czf "$out" -C "$PDRX_CONFIG" .
    log_success "Exported to $out"
  else
    tar -czf - -C "$PDRX_HOME" config state 2>/dev/null \
      || tar -czf - -C "$PDRX_CONFIG" .
  fi
}

# =============================================================================
# ANSIBLE EXPORT  (new in 1.7.0)
# =============================================================================
#
# `pdrx export --ansible [DIR]` is a ONE-WAY, best-effort snapshot generator.
# It reads the same packages.conf / sources.conf / systemd.conf / dotfiles /
# hooks that `pdrx apply` uses, and emits a standalone, runnable Ansible
# role + playbook from them. It is NOT a runtime dependency of `pdrx apply` —
# pdrx never shells out to ansible-playbook itself. This exists purely so
# the declarative state pdrx already maintains can be handed to a teammate
# or CI system that standardizes on Ansible.
#
# Coverage:
#   apt/dnf/yum/pacman/zypper/brew/flatpak/snap/cargo -> real modules
#     (pacman/zypper/flatpak/snap/cargo require the community.general
#     collection — noted in the generated README)
#   winget -> NOT translated. No reliable public Ansible module exists for
#     winget as of this writing; emitting a fake task would silently produce
#     a playbook that fails or does nothing on Windows hosts, which is worse
#     than being upfront. Emitted as a commented block with the raw package
#     list, for manual conversion (e.g. chocolatey.chocolatey or a
#     win_command wrapper the user writes themselves).
#   sources -> apt_repository/apt_key, get_url into yum.repos.d,
#     community.general.zypper_repository, community.general.flatpak_remote
#   systemd -> ansible.builtin.systemd_service
#   dotfiles -> ansible.builtin.copy, files bundled into the role
#   hook -> ansible.builtin.script, files bundled into the role

_yaml_q() {
  # Double-quote a scalar for safe YAML embedding: escape backslashes then
  # double quotes, so package names/URLs with special chars can't break
  # the generated document.
  printf '%s' "$1" | sed -e 's/\\/\\\\/g' -e 's/"/\\"/g'
}

_ansible_task_pkg_list() {
  # Emits: '      - "pkg1"\n      - "pkg2"\n' for a given pm from packages.conf
  local pm="$1" pinned="$2"  # pinned: "yes" or "no"
  [ -f "$PACKAGES_CONF" ] || return 0
  local line
  while IFS= read -r line; do
    [[ "$line" == \#* ]] || [ -z "$line" ] && continue
    [[ "$line" == "$pm:"* ]] || continue
    local rest="${line#*:}"
    local name="$rest" version=""
    if [[ "$rest" == *=* ]]; then
      name="${rest%%=*}"
      version="${rest#*=}"
    fi
    if [ "$pinned" = "yes" ] && [ -z "$version" ]; then continue; fi
    if [ "$pinned" = "no" ]  && [ -n "$version" ]; then continue; fi
    if [ "$pinned" = "yes" ]; then
      printf '      - name: "%s"\n        version: "%s"\n' "$(_yaml_q "$name")" "$(_yaml_q "$version")"
    else
      printf '      - "%s"\n' "$(_yaml_q "$name")"
    fi
  done < "$PACKAGES_CONF"
}

_ansible_pm_has_pkgs() {
  local pm="$1"
  [ -f "$PACKAGES_CONF" ] || return 1
  grep -qE "^${pm}:" "$PACKAGES_CONF" 2>/dev/null
}

run_export_ansible() {
  local outdir="${1:-./pdrx-ansible-export}"
  outdir="${outdir%/}"
  local role_dir="$outdir/roles/pdrx_system"

  mkdir -p "$role_dir/tasks" "$role_dir/files/dotfiles" "$role_dir/files/hooks"

  # ---- bundle dotfiles (preserving relative paths) ----
  local dotfile_count=0
  if [ -f "$TRACKED_DOTFILES" ]; then
    local rel
    while IFS= read -r rel; do
      [ -z "$rel" ] && continue
      local src="$DOTFILES_DIR/$rel"
      [ -f "$src" ] || continue
      mkdir -p "$role_dir/files/dotfiles/$(dirname "$rel")"
      cp "$src" "$role_dir/files/dotfiles/$rel"
      dotfile_count=$((dotfile_count + 1))
    done < "$TRACKED_DOTFILES"
  fi

  # ---- bundle post-apply hook ----
  local have_hook=false
  if [ -x "$HOOKS_DIR/post-apply.sh" ]; then
    cp "$HOOKS_DIR/post-apply.sh" "$role_dir/files/hooks/post-apply.sh"
    have_hook=true
  fi

  # ---- tasks/main.yml ----
  {
    echo "---"
    echo "# Generated by pdrx export --ansible on $(date_iso_seconds)"
    echo "# Source: $PDRX_CONFIG (packages.conf, sources.conf, systemd.conf, dotfiles, hooks)"
    echo "# This is a ONE-WAY, point-in-time snapshot. Re-run 'pdrx export --ansible'"
    echo "# after future 'pdrx sync' calls to refresh it — it is not kept in sync"
    echo "# automatically."
    echo ""

    # -- sources (must run before packages) --
    if [ -f "$SOURCES_CONF" ] && grep -qv '^#\|^$' "$SOURCES_CONF" 2>/dev/null; then
      echo "# ---------------------------------------------------------------"
      echo "# Repo / PPA / remote sources (from sources.conf)"
      echo "# ---------------------------------------------------------------"
      local line
      while IFS= read -r line; do
        [[ "$line" == \#* ]] && continue
        [ -z "$line" ] && continue
        local pm="${line%%:*}" rest="${line#*:}"
        local kind="${rest%%=*}" val="${rest#*=}"
        case "$pm:$kind" in
          apt:ppa)
            cat << YAML
- name: "Add apt PPA: $(_yaml_q "$val")"
  ansible.builtin.apt_repository:
    repo: "$(_yaml_q "$val")"
    state: present
  become: true
  tags: [sources, apt]

YAML
            ;;
          apt:repo)
            local repo_line="${val%%|*}" rem="${val#*|}"
            local keyring="${rem%%|*}" key_url="${rem#*|}"
            cat << YAML
- name: "Fetch apt signing key for: $(_yaml_q "$repo_line")"
  ansible.builtin.get_url:
    url: "$(_yaml_q "$key_url")"
    dest: "/tmp/pdrx-key-$(echo "$repo_line" | md5sum | cut -c1-8).gpg"
  become: true
  tags: [sources, apt]

- name: "Dearmor and install apt keyring: $(_yaml_q "$keyring")"
  ansible.builtin.shell: |
    gpg --dearmor < /tmp/pdrx-key-$(echo "$repo_line" | md5sum | cut -c1-8).gpg > "$(_yaml_q "$keyring")"
  args:
    creates: "$(_yaml_q "$keyring")"
  become: true
  tags: [sources, apt]

- name: "Add apt repo line: $(_yaml_q "$repo_line")"
  ansible.builtin.apt_repository:
    repo: "$(_yaml_q "$repo_line")"
    filename: "pdrx-$(echo "$repo_line" | md5sum | cut -c1-8)"
    state: present
  become: true
  tags: [sources, apt]

YAML
            ;;
          dnf:repo)
            cat << YAML
- name: "Add dnf repo: $(_yaml_q "$val")"
  ansible.builtin.get_url:
    url: "$(_yaml_q "$val")"
    dest: "/etc/yum.repos.d/pdrx-$(echo "$val" | md5sum | cut -c1-8).repo"
  become: true
  tags: [sources, dnf]

YAML
            ;;
          zypper:repo)
            cat << YAML
- name: "Add zypper repo: $(_yaml_q "$val")"
  community.general.zypper_repository:
    repo: "$(_yaml_q "$val")"
    state: present
    auto_import_keys: true
  become: true
  tags: [sources, zypper]

YAML
            ;;
          flatpak:remote)
            local name="${val%%|*}" url="${val#*|}"
            cat << YAML
- name: "Add flatpak remote: $(_yaml_q "$name")"
  community.general.flatpak_remote:
    name: "$(_yaml_q "$name")"
    flatpakrepo_url: "$(_yaml_q "$url")"
    state: present
  become: true
  tags: [sources, flatpak]

YAML
            ;;
          *) ;;
        esac
      done < "$SOURCES_CONF"
    fi

    # -- packages, one task block per PM --
    echo "# ---------------------------------------------------------------"
    echo "# Packages (from packages.conf)"
    echo "# ---------------------------------------------------------------"

    if _ansible_pm_has_pkgs apt; then
      local unpinned pinned
      unpinned=$(_ansible_task_pkg_list apt no)
      if [ -n "$unpinned" ]; then
        cat << YAML
- name: "Install apt packages (unpinned)"
  ansible.builtin.apt:
    name:
$unpinned
    state: present
    update_cache: true
  become: true
  tags: [packages, apt]

YAML
      fi
      pinned=$(_ansible_task_pkg_list apt yes)
      if [ -n "$pinned" ]; then
        cat << YAML
- name: "Install pinned apt packages"
  ansible.builtin.apt:
    name: "{{ item.name }}={{ item.version }}"
    state: present
  loop:
$pinned
  become: true
  tags: [packages, apt]

YAML
      fi
    fi

    if _ansible_pm_has_pkgs dnf; then
      local unpinned pinned
      unpinned=$(_ansible_task_pkg_list dnf no)
      if [ -n "$unpinned" ]; then
        cat << YAML
- name: "Install dnf packages (unpinned)"
  ansible.builtin.dnf:
    name:
$unpinned
    state: present
  become: true
  tags: [packages, dnf]

YAML
      fi
      pinned=$(_ansible_task_pkg_list dnf yes)
      if [ -n "$pinned" ]; then
        cat << YAML
- name: "Install pinned dnf packages"
  ansible.builtin.dnf:
    name: "{{ item.name }}-{{ item.version }}"
    state: present
  loop:
$pinned
  become: true
  tags: [packages, dnf]

YAML
      fi
    fi

    if _ansible_pm_has_pkgs yum; then
      local unpinned
      unpinned=$(_ansible_task_pkg_list yum no)
      if [ -n "$unpinned" ]; then
        cat << YAML
- name: "Install yum packages"
  ansible.builtin.yum:
    name:
$unpinned
    state: present
  become: true
  tags: [packages, yum]

YAML
      fi
    fi

    if _ansible_pm_has_pkgs pacman; then
      local unpinned
      unpinned=$(_ansible_task_pkg_list pacman no)
      if [ -n "$unpinned" ]; then
        cat << YAML
- name: "Install pacman packages"
  community.general.pacman:
    name:
$unpinned
    state: present
  become: true
  tags: [packages, pacman]
  # NOTE: pacman version pinning is not supported by pdrx or this module;
  # any pinned pacman entries in packages.conf were skipped (there should
  # be none — pdrx warns at install time when pinning is unsupported).

YAML
      fi
    fi

    if _ansible_pm_has_pkgs zypper; then
      local unpinned
      unpinned=$(_ansible_task_pkg_list zypper no)
      if [ -n "$unpinned" ]; then
        cat << YAML
- name: "Install zypper packages"
  community.general.zypper:
    name:
$unpinned
    state: present
  become: true
  tags: [packages, zypper]

YAML
      fi
    fi

    if _ansible_pm_has_pkgs brew; then
      local unpinned
      unpinned=$(_ansible_task_pkg_list brew no)
      if [ -n "$unpinned" ]; then
        cat << YAML
- name: "Install homebrew packages"
  community.general.homebrew:
    name:
$unpinned
    state: present
  tags: [packages, brew]

YAML
      fi
    fi

    if _ansible_pm_has_pkgs flatpak; then
      local unpinned
      unpinned=$(_ansible_task_pkg_list flatpak no)
      if [ -n "$unpinned" ]; then
        cat << YAML
- name: "Install flatpak packages"
  community.general.flatpak:
    name:
$unpinned
    state: present
  tags: [packages, flatpak]

YAML
      fi
    fi

    if _ansible_pm_has_pkgs snap; then
      local unpinned
      unpinned=$(_ansible_task_pkg_list snap no)
      if [ -n "$unpinned" ]; then
        cat << YAML
- name: "Install snap packages"
  community.general.snap:
    name:
$unpinned
    state: present
  become: true
  tags: [packages, snap]

YAML
      fi
    fi

    if _ansible_pm_has_pkgs cargo; then
      local unpinned pinned
      unpinned=$(_ansible_task_pkg_list cargo no)
      if [ -n "$unpinned" ]; then
        cat << YAML
- name: "Install cargo packages (unpinned)"
  community.general.cargo:
    name:
$unpinned
    state: present
  tags: [packages, cargo]

YAML
      fi
      pinned=$(_ansible_task_pkg_list cargo yes)
      if [ -n "$pinned" ]; then
        cat << YAML
- name: "Install pinned cargo packages"
  community.general.cargo:
    name: "{{ item.name }}"
    version: "{{ item.version }}"
    state: present
  loop:
$pinned
  tags: [packages, cargo]

YAML
      fi
    fi

    if _ansible_pm_has_pkgs winget; then
      echo "# ---------------------------------------------------------------"
      echo "# winget packages: NOT auto-translated (no reliable public"
      echo "# Ansible winget module exists as of this writing). Raw entries"
      echo "# from packages.conf, for manual conversion:"
      echo "# ---------------------------------------------------------------"
      local line
      while IFS= read -r line; do
        [[ "$line" == "winget:"* ]] || continue
        echo "#   ${line#winget:}"
      done < "$PACKAGES_CONF"
      echo ""
    fi

    # -- systemd units --
    if [ -f "$SYSTEMD_CONF" ] && grep -qv '^#\|^$' "$SYSTEMD_CONF" 2>/dev/null; then
      echo "# ---------------------------------------------------------------"
      echo "# systemd units (from systemd.conf)"
      echo "# ---------------------------------------------------------------"
      local line
      while IFS= read -r line; do
        [[ "$line" == \#* ]] && continue
        [ -z "$line" ] && continue
        local scope="${line%%:*}" unit="${line#*:}"
        [ -z "$unit" ] && continue
        if [ "$scope" = "system" ]; then
          cat << YAML
- name: "Enable systemd unit (system): $(_yaml_q "$unit")"
  ansible.builtin.systemd_service:
    name: "$(_yaml_q "$unit")"
    enabled: true
  become: true
  tags: [systemd]

YAML
        else
          cat << YAML
- name: "Enable systemd unit (user): $(_yaml_q "$unit")"
  ansible.builtin.systemd_service:
    name: "$(_yaml_q "$unit")"
    scope: user
    enabled: true
  tags: [systemd]

YAML
        fi
      done < "$SYSTEMD_CONF"
    fi

    # -- dotfiles --
    if [ "$dotfile_count" -gt 0 ]; then
      echo "# ---------------------------------------------------------------"
      echo "# Dotfiles ($dotfile_count tracked file(s))"
      echo "# ---------------------------------------------------------------"
      local rel
      while IFS= read -r rel; do
        [ -z "$rel" ] && continue
        [ -f "$role_dir/files/dotfiles/$rel" ] || continue
        cat << YAML
- name: "Deploy dotfile: $(_yaml_q "$rel")"
  ansible.builtin.copy:
    src: "dotfiles/$rel"
    dest: "{{ ansible_env.HOME }}/$rel"
    mode: preserve
  tags: [dotfiles]

YAML
      done < "$TRACKED_DOTFILES"
    fi

    # -- post-apply hook --
    if [ "$have_hook" = "true" ]; then
      cat << 'YAML'
# ---------------------------------------------------------------
# post-apply hook (from ~/.pdrx/config/hooks/post-apply.sh)
# ---------------------------------------------------------------
- name: "Run pdrx post-apply hook"
  ansible.builtin.script: "hooks/post-apply.sh"
  tags: [hooks]

YAML
    fi
  } > "$role_dir/tasks/main.yml.body"

  # FIX: a tasks/main.yml with only comments (nothing declared yet in pdrx)
  # parses as YAML null, which Ansible rejects — "tasks must be a list".
  # Force an explicit empty list so the export is always a valid,
  # runnable (if no-op) role.
  if ! grep -q '^- name:' "$role_dir/tasks/main.yml.body"; then
    echo "# Nothing declared in pdrx yet (no packages/sources/systemd/dotfiles/hook)." \
      >> "$role_dir/tasks/main.yml.body"
    echo "[]" >> "$role_dir/tasks/main.yml.body"
  fi
  mv "$role_dir/tasks/main.yml.body" "$role_dir/tasks/main.yml"

  # ---- playbook.yml ----
  cat > "$outdir/playbook.yml" << YAML
---
- name: Reproduce system state exported from pdrx
  hosts: all
  roles:
    - pdrx_system
YAML

  # ---- inventory.ini ----
  cat > "$outdir/inventory.ini" << 'YAML'
# Edit this to target the real host(s) you want to apply this to.
# Defaults to localhost for a quick smoke test:
#   ansible-playbook -i inventory.ini playbook.yml --check
[all]
localhost ansible_connection=local
YAML

  # ---- README ----
  local needs_community_general=false
  for pm in pacman zypper flatpak snap cargo; do
    _ansible_pm_has_pkgs "$pm" && needs_community_general=true
  done
  if [ -f "$SOURCES_CONF" ] && grep -qE '^zypper:|^flatpak:' "$SOURCES_CONF" 2>/dev/null; then
    needs_community_general=true
  fi

  cat > "$outdir/README.md" << EOF
# pdrx Ansible export

Generated by \`pdrx export --ansible\` on $(date_iso_seconds) from
\`$PDRX_CONFIG\`. **This is a one-way, point-in-time snapshot** — it is not
kept in sync automatically. Re-run the export after future \`pdrx sync\`
calls if you want it refreshed.

## Requirements

\`\`\`
pip install --user ansible-core
$( [ "$needs_community_general" = "true" ] && echo "ansible-galaxy collection install community.general" )
\`\`\`

## Usage

\`\`\`
# Dry run against localhost first:
ansible-playbook -i inventory.ini playbook.yml --check --diff

# Edit inventory.ini to point at your real target host(s), then:
ansible-playbook -i inventory.ini playbook.yml --ask-become-pass
\`\`\`

Tasks are tagged so you can apply a subset, e.g.:

\`\`\`
ansible-playbook -i inventory.ini playbook.yml --tags packages,systemd
\`\`\`

## Known gaps vs. \`pdrx apply\`

- **winget packages are not translated.** No reliable public Ansible module
  exists for winget. Raw package names are left as comments in
  \`roles/pdrx_system/tasks/main.yml\` for manual conversion.
- **pacman package pinning** isn't supported by pdrx itself, so there is
  nothing to translate here either — all pacman entries are unpinned by
  construction.
- **apt/dnf pinned versions** are translated using each module's
  \`name=version\` / \`name-version\` syntax; verify the exact version string
  is still resolvable in your target's repos before a real run — pinned
  versions age out of repos over time on rolling package indices.
- Task order matches pdrx's own \`apply\` order (sources → packages →
  systemd → dotfiles → hook), but Ansible's own idempotency checks per
  module are what actually govern re-run safety, not pdrx's.
EOF

  # ---- tarball for convenience ----
  local tarball="${outdir}.tar.gz"
  tar -czf "$tarball" -C "$(dirname "$outdir")" "$(basename "$outdir")" 2>/dev/null || true

  log_success "Ansible export written to $outdir/ (also packaged as $tarball)"
  log_info "Packages: apt=$(_ansible_pm_has_pkgs apt && echo yes || echo no), dnf=$(_ansible_pm_has_pkgs dnf && echo yes || echo no), pacman=$(_ansible_pm_has_pkgs pacman && echo yes || echo no)"
  [ "$needs_community_general" = "true" ] && log_info "Requires the community.general collection — see README.md"
  _ansible_pm_has_pkgs winget && log_warning "winget packages were NOT translated — see README.md"
}

run_import() {
  require_initialized
  local file="$1"
  [ -z "$file" ] && { log_error "Usage: pdrx import <file>"; exit 1; }
  [ ! -f "$file" ] && { log_error "Not found: $file"; exit 1; }
  tar -xzf "$file" -C "$PDRX_HOME" 2>/dev/null \
    || tar -xzf "$file" -C "$PDRX_CONFIG" 2>/dev/null
  log_success "Imported from $file"
}

run_update() {
  require_initialized
  local pm
  for pm in $(detect_available_pms); do
    log_info "Updating $pm index..."
    pm_update "$pm" 2>/dev/null || log_warning "Update failed for $pm"
  done
  log_success "Package indexes updated"
}

run_upgrade() {
  require_initialized
  local pm
  for pm in $(detect_available_pms); do
    log_info "Upgrading packages via $pm..."
    pm_upgrade "$pm" 2>/dev/null || log_warning "Upgrade failed for $pm"
  done
  log_success "Upgrade complete for all package managers"
}

run_destroy() {
  log_header "Destroy pdrx"
  echo "This will:"
  echo "  • Restore tracked dotfiles: replace symlinks with real files (content from pdrx copy)"
  echo "  • Remove $PDRX_HOME (config, backups, state)"
  echo "  • Remove pdrx from ~/.local/bin"
  echo "  • Remove pdrx manpage (pdrx.1)"
  echo ""
  echo "Installed packages, added repo sources, and enabled systemd units will NOT be reverted."
  echo ""
  if [ "${DRY_RUN:-false}" = "true" ]; then
    log_info "[dry-run] no changes will be made"
  elif [ "${YES:-false}" != "true" ]; then
    printf "Type 'yes' to continue: "
    local r
    read -r r
    [ "$r" != "yes" ] && return 0
  fi

  if [ -f "$TRACKED_DOTFILES" ]; then
    local rel
    while IFS= read -r rel; do
      [ -z "$rel" ] && continue
      local dest="$HOME/$rel"
      local src="$DOTFILES_DIR/$rel"
      if [ "${DRY_RUN:-false}" = "true" ]; then
        if [ -L "$dest" ]; then
          log_info "[dry-run] would restore $rel (symlink -> real file)"
        fi
        continue
      fi
      if [ -L "$dest" ]; then
        rm -f "$dest"
        if [ -f "$src" ]; then
          mkdir -p "$(dirname "$dest")"
          cp "$src" "$dest"
          log_success "Restored $rel (symlink replaced with real file)"
        else
          log_warning "Removed symlink $rel (pdrx copy missing)"
        fi
      fi
    done < "$TRACKED_DOTFILES"
  fi

  if [ "${DRY_RUN:-false}" = "true" ]; then
    log_info "[dry-run] would remove $PDRX_HOME"
    [ -f "$HOME/.local/bin/pdrx" ] && log_info "[dry-run] would remove $HOME/.local/bin/pdrx"
    # Check for manpage in common locations
    local man_dirs=(
      "$HOME/.local/share/man/man1"
      "$HOME/.local/man/man1"
      "/usr/local/share/man/man1"
      "/usr/share/man/man1"
    )
    for d in "${man_dirs[@]}"; do
      [ -f "$d/pdrx.1" ] && log_info "[dry-run] would remove $d/pdrx.1"
    done
    log_info "[dry-run] would strip pdrx PATH lines from ~/.bashrc and ~/.zshrc"
    log_info "[dry-run] destroy preview complete; nothing was changed"
    return 0
  fi

  rm -rf "$PDRX_HOME"
  [ -f "$HOME/.local/bin/pdrx" ] && rm -f "$HOME/.local/bin/pdrx"
  
  # Remove manpage from common locations
  local man_dirs=(
    "$HOME/.local/share/man/man1"
    "$HOME/.local/man/man1"
    "/usr/local/share/man/man1"
    "/usr/share/man/man1"
  )
  for d in "${man_dirs[@]}"; do
    if [ -f "$d/pdrx.1" ]; then
      rm -f "$d/pdrx.1"
      log_info "Removed manpage from $d/pdrx.1"
    fi
  done
  local rc
  for rc in "$HOME/.bashrc" "$HOME/.zshrc"; do
    if [ -f "$rc" ]; then
      # shellcheck disable=SC2016
      grep -v -F '# Added by pdrx' "$rc" \
        | grep -v -F 'export PATH="$PATH:$HOME/.local/bin"' \
        > "${rc}.tmp" 2>/dev/null && mv "${rc}.tmp" "$rc"
    fi
  done
  log_success "pdrx destroyed. Dotfiles restored to real files; symlinks removed."
}

run_install_self() {
  log_header "Install pdrx"
  local install_dir="$HOME/.local/bin"
  local self
  self="$(get_script_path)"
  [ -f "$self" ] || self="$(cd "$(dirname "$0")" && pwd)/pdrx"
  local script_dir
  script_dir="$(dirname "$self")"
  
  # Install the binary
  mkdir -p "$install_dir"
  cp "$self" "$install_dir/pdrx"
  chmod +x "$install_dir/pdrx"
  
  # Install the manpage if it exists alongside the script
  if [ -f "$script_dir/pdrx.1" ]; then
    local man_dir="$HOME/.local/share/man/man1"
    mkdir -p "$man_dir"
    cp "$script_dir/pdrx.1" "$man_dir/pdrx.1"
    log_success "Installed manpage to $man_dir/pdrx.1"
  fi
  
  # shellcheck disable=SC2016
  local path_line='export PATH="$PATH:$HOME/.local/bin"'
  local rc
  for rc in "$HOME/.bashrc" "$HOME/.zshrc"; do
    if [ -f "$rc" ]; then
      if ! grep -q '\.local/bin' "$rc"; then
        printf '\n# Added by pdrx\n%s\n' "$path_line" >> "$rc"
      fi
    fi
  done
  log_success "Installed to $install_dir/pdrx. Run: source ~/.bashrc && pdrx init"
}

# =============================================================================
# SELF-UPDATE  (hardened in 1.7.0)
# =============================================================================
#
# FIX (1.7.0): previously curled a raw script from GitHub and chmod +x/
# replaced the running binary with ZERO integrity verification — anyone able
# to MITM the connection or briefly compromise the repo/CDN got arbitrary
# code execution on every machine that ran `pdrx self-update`. This now:
#   1. Pins to a tagged release asset instead of the mutable `main` branch.
#   2. Downloads the accompanying .sha256 checksum file published in the
#      same release and verifies the script against it before replacing
#      the installed binary.
#   3. Refuses to proceed (rather than silently trusting) if the checksum
#      file is missing or doesn't match.
#
# NOTE: this requires the pdrx release process to publish `pdrx` and
# `pdrx.sha256` (or a combined SHA256SUMS file) as GitHub release assets —
# see the PR description for the accompanying release workflow change.

run_self_update() {
  log_header "Self-update pdrx"
  local install_path
  install_path="$(get_script_path)"

  if ! command -v curl >/dev/null 2>&1 && ! command -v wget >/dev/null 2>&1; then
    log_error "curl or wget is required for self-update"
    exit 1
  fi
  if ! command -v sha256sum >/dev/null 2>&1; then
    log_error "sha256sum is required for self-update (integrity verification)"
    exit 1
  fi

  log_info "Checking latest release..."
  local api_url="https://api.github.com/repos/stefan-hacks/pdrx/releases/latest"
  local rel_json
  rel_json=$(_fetch_url "$api_url") || { log_error "Failed to query latest release"; exit 1; }

  local tag
  # FIX (1.8.0): same bare-assignment pipefail trap as the `remove` fix
  # above — if the API response doesn't contain "tag_name" (malformed
  # response, rate limit, etc.), grep -m1 exits 1 and would silently kill
  # the whole self-update with no error message. || true neutralizes it;
  # the existing [ -z "$tag" ] check below still catches the real failure.
  tag=$(printf '%s' "$rel_json" | grep -m1 '"tag_name"' | sed -E 's/.*"tag_name": *"([^"]+)".*/\1/' || true)
  [ -z "$tag" ] && { log_error "Could not determine latest release tag"; exit 1; }

  local remote_version="${tag#v}"
  if [ "$remote_version" = "$VERSION" ]; then
    log_info "Already up to date (v$VERSION)"
    return 0
  fi

  local script_url="https://github.com/stefan-hacks/pdrx/releases/download/${tag}/pdrx"
  local sum_url="https://github.com/stefan-hacks/pdrx/releases/download/${tag}/pdrx.sha256"

  local tmp tmp_sum
  tmp=$(mktemp)
  tmp_sum=$(mktemp)
  _fetch_to_file "$script_url" "$tmp" || { log_error "Failed to download pdrx $tag"; rm -f "$tmp" "$tmp_sum"; exit 1; }
  if ! _fetch_to_file "$sum_url" "$tmp_sum"; then
    log_error "Could not download checksum file (pdrx.sha256) for $tag — refusing to install unverified update."
    log_error "This is a hard stop: self-update never replaces the binary without a verified checksum."
    rm -f "$tmp" "$tmp_sum"
    exit 1
  fi

  local expected actual
  expected=$(awk '{print $1}' "$tmp_sum" | head -1)
  actual=$(sha256sum "$tmp" | awk '{print $1}')
  if [ -z "$expected" ] || [ "$expected" != "$actual" ]; then
    log_error "Checksum verification FAILED for $tag."
    log_error "  expected: ${expected:-<empty>}"
    log_error "  actual:   $actual"
    log_error "Not installing. This could mean a corrupted download or a tampered release — investigate before retrying."
    rm -f "$tmp" "$tmp_sum"
    exit 1
  fi

  log_success "Checksum verified ($actual)"
  log_info "Updating $VERSION → $remote_version"
  chmod +x "$tmp"
  mv "$tmp" "$install_path"
  rm -f "$tmp_sum"

  # Also update the manpage
  log_info "Updating manpage..."
  local man_url="https://github.com/stefan-hacks/pdrx/releases/download/${tag}/pdrx.1"
  local man_dest=""
  local man_dirs=(
    "$HOME/.local/share/man/man1"
    "$HOME/.local/man/man1"
    "/usr/local/share/man/man1"
    "/usr/share/man/man1"
  )

  # Find existing manpage location
  for d in "${man_dirs[@]}"; do
    if [ -f "$d/pdrx.1" ]; then
      man_dest="$d/pdrx.1"
      break
    fi
  done

  # If no existing manpage, use ~/.local/share/man/man1 as default
  if [ -z "$man_dest" ]; then
    man_dest="$HOME/.local/share/man/man1/pdrx.1"
    mkdir -p "$HOME/.local/share/man/man1"
  fi

  local tmp_man
  tmp_man=$(mktemp)
  if _fetch_to_file "$man_url" "$tmp_man" 2>/dev/null; then
    # Verify it looks like a manpage (contains .TH directive)
    if grep -q '^\.TH' "$tmp_man" 2>/dev/null; then
      mv "$tmp_man" "$man_dest"
      log_success "Updated manpage to $man_dest"
    else
      rm -f "$tmp_man"
      log_warning "Manpage download did not contain valid manpage content"
    fi
  else
    rm -f "$tmp_man"
    log_warning "Could not download manpage (this is optional)"
  fi

  log_action "self_update" "" "" "ok" "$VERSION->$remote_version"
  log_success "Updated pdrx to v$remote_version. Re-run pdrx to use the new version."
}

_fetch_url() {
  local url="$1"
  if command -v curl >/dev/null 2>&1; then
    curl -fsSL -H "Accept: application/vnd.github+json" "$url"
  else
    wget -qO- "$url"
  fi
}

_fetch_to_file() {
  local url="$1" dest="$2"
  if command -v curl >/dev/null 2>&1; then
    curl -fsSL "$url" -o "$dest"
  else
    wget -qO "$dest" "$url"
  fi
}

# =============================================================================
# HELP
# =============================================================================

show_help() {
  cat << EOF
${BOLD}${CYAN}pdrx v${VERSION} - Portable Dynamic Reproducible gnu/linuX${NC}
Pure Bash reproducible system setup. No Nix. Works on all major Linux distros + Windows (winget).

${BOLD}SCOPE:${NC} packages, repo sources, dotfiles, DE settings, enabled systemd units.
Deliberately NOT in scope: partitioning, fstab, LUKS, OS provisioning — use
cloud-init / Ansible / Nix for that layer; pdrx assumes it already exists.

${BOLD}USAGE:${NC} pdrx [OPTIONS] COMMAND [ARGS...]

${BOLD}OPTIONS:${NC}
  -h, --help       Show this help
  -v, --version    Show version
  -q, --quiet      Less output
  -d, --debug      Verbose debug output
  -y, --yes        No confirmation prompts
  -n, --dry-run    Show what would be done (no changes)
  -c, --config DIR Use DIR as pdrx home (default: ~/.pdrx)
  --install        Install pdrx to ~/.local/bin

${BOLD}COMMANDS:${NC}
  init                            Initialize pdrx
  status                          Show status (config, PMs, packages, sources, units)
  doctor, fsck                    Audit declared config vs. actual system state, report drift
  install [--pin[=VER]] [pkg...]  Install package(s); --pin records the installed version
  install --pm PM [--pin[=VER]] [pkg...]
                                  Install with a specific PM
  remove [pkg...]                 Remove package(s) and update config (-n for dry-run)
  list                            List packages in declarative config
  search [--parallel] TERM [1 2 ...]
                                  Search across PMs (optional PM numbers; --parallel for speed)
  source add <pm> ...             Declare a repo/PPA/remote (apt, apt-repo, dnf, zypper, flatpak)
  source list                     List declared sources
  source apply                    Re-apply all declared sources (also runs at start of 'apply')
  sync                            Sync packages, sources refs, systemd units, and desktop into config
  sync-dotfiles                   Auto-discover and track common dotfiles (.bashrc, .zshrc, .config/nvim, etc.)
  apply [--parallel]              Apply full declarative config (sources → packages → dotfiles → DE → units → hook)
  track FILE                      Track dotfile (copy + symlink)
  untrack FILE                    Untrack dotfile
  hook edit                       Create/open the post-apply hook script (~/.pdrx/config/hooks/post-apply.sh)
  backup [LABEL]                  Create a backup
  restore PATH                    Restore config from backup path
  generations                     List backups with reference numbers
  clean [ARG]                     Clean backups: all|current|<ref>|<ref1-ref2>
  rollback [N]                    Rollback to Nth most-recent backup (default: 1 = newest)
  sync-desktop                    Export desktop/DE state
  sync-desktop --restore          Restore desktop state
  history [N]                     Show last N audit log entries (default 30)
  update                          Refresh all PM package indexes
  upgrade                         Upgrade all packages via each PM
  self-update                     Update pdrx itself (checksum-verified, pinned to latest release)
  export [FILE]                   Export config as tarball
  export --ansible [DIR]          One-way export as a runnable Ansible role + playbook
  import FILE                     Import config from tarball
  destroy                         Restore dotfiles and remove pdrx (-y skips prompt)

${BOLD}SUPPORTED PACKAGE MANAGERS:${NC}
  apt, dnf, yum, pacman, zypper, brew, flatpak, snap, cargo, winget

${BOLD}DECLARATIVE FORMAT (packages.conf):${NC}
  pm:package              unpinned (default)
  pm:package=version      pinned version (written by install --pin)

${BOLD}EXAMPLES:${NC}
  pdrx install vim                            # interactive PM selection
  pdrx install --pm apt vim                   # install via apt
  pdrx install --pm cargo rg --pin            # install and pin current version
  pdrx source add apt-repo 'deb [...] jammy stable' /etc/apt/keyrings/docker.gpg https://download.docker.com/linux/ubuntu/gpg
  pdrx source add dnf https://download.docker.com/linux/fedora/docker-ce.repo
  pdrx remove vim                             # remove (uses recorded PM)
  pdrx -n apply --parallel                    # dry-run a full parallel restore
  pdrx hook edit                              # add custom post-apply glue (udev reload, etc.)
  pdrx self-update                            # checksum-verified update to latest release
  pdrx upgrade                                # upgrade all packages
  pdrx history 50                             # show last 50 audit log entries

EOF
}

show_version() {
  echo "pdrx ${VERSION}"
}

# =============================================================================
# MAIN
# =============================================================================

QUIET=false
DEBUG=false
YES=false
DRY_RUN=false

while [ $# -gt 0 ]; do
  case "$1" in
    -h|--help)    show_help; exit 0 ;;
    -v|--version) show_version; exit 0 ;;
    -q|--quiet)   QUIET=true; shift ;;
    -d|--debug)   DEBUG=true; shift ;;
    -y|--yes)     YES=true; shift ;;
    -n|--dry-run) DRY_RUN=true; shift ;;
    -c|--config)  PDRX_HOME="$2"; shift 2 ;;
    --install)    run_install_self; exit 0 ;;
    *)            break ;;
  esac
done

# Re-derive paths if PDRX_HOME was overridden by -c/--config
PDRX_CONFIG="$PDRX_HOME/config"
PDRX_BACKUP="$PDRX_HOME/backups"
PDRX_STATE="$PDRX_HOME/state"
PACKAGES_CONF="$PDRX_CONFIG/packages.conf"
SOURCES_CONF="$PDRX_CONFIG/sources.conf"
SYSTEMD_CONF="$PDRX_CONFIG/systemd.conf"
DOTFILES_DIR="$PDRX_CONFIG/dotfiles"
TRACKED_DOTFILES="$PDRX_STATE/tracked-dotfiles"
DESKTOP_EXPORT="$PDRX_CONFIG/desktop-export"
GENERATIONS_FILE="$PDRX_STATE/generations"
HOOKS_DIR="$PDRX_CONFIG/hooks"
LOG_FILE="$PDRX_STATE/pdrx.log"

[ $# -eq 0 ] && { show_help; exit 0; }

CMD="$1"
shift

log_debug "pdrx version: $VERSION"
log_debug "PDRX_HOME=$PDRX_HOME"
log_debug "command: $CMD $*"
log_debug "initialized: $(is_initialized && echo yes || echo no)"

case "$CMD" in
  init)        run_init "$@" ;;
  status)      run_status "$@" ;;
  doctor|fsck) run_doctor "$@" ;;
  install)
    if [ "${1:-}" = "--pm" ]; then
      shift
      run_install_with_pm "$@"
    else
      run_install "$@"
    fi
    ;;
  remove)      run_remove "$@" ;;
  list)        run_list "$@" ;;
  search)      run_search "$@" ;;
  source)      run_source "$@" ;;
  sync)        run_sync "$@" ;;
  sync-dotfiles) run_sync_dotfiles "$@" ;;
  apply)       run_apply "$@" ;;
  track)       run_track "$@" ;;
  untrack)     run_untrack "$@" ;;
  hook)
    if [ "${1:-}" = "edit" ]; then
      run_hook_edit
    else
      log_error "Usage: pdrx hook edit"
      exit 1
    fi
    ;;
  backup)      run_backup "$@" ;;
  restore)     run_restore "$@" ;;
  generations) run_generations "$@" ;;
  clean)       run_clean "$@" ;;
  rollback)    run_rollback "$@" ;;
  sync-desktop)
    if [ "${1:-}" = "--restore" ]; then
      run_restore_desktop
    else
      run_sync_desktop
    fi
    ;;
  history)     run_history "$@" ;;
  update)      run_update "$@" ;;
  upgrade)     run_upgrade "$@" ;;
  self-update) run_self_update ;;
  export)      run_export "$@" ;;
  import)      run_import "$@" ;;
  destroy)     run_destroy "$@" ;;
  *)
    log_error "Unknown command: $CMD"
    show_help
    exit 1
    ;;
esac
