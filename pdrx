# =============================================================================
# PORTABLE HELPERS
# =============================================================================

# Wrapper around `sudo`: if we're already root, or `sudo` simply isn't
# installed (common in minimal containers), run the command directly instead
# of failing with "sudo: command not found".
sudo() {
  if [ "${EUID:-$(id -u)}" -eq 0 ]; then
    command "$@"
  elif command -v sudo >/dev/null 2>&1; then
    command sudo "$@"
  else
    log_warning "sudo not found and not running as root; attempting without privilege escalation"
    command "$@"
  fi
}

get_script_path() {
  local src="${BASH_SOURCE[0]:-$0}"
  local dir
  while true; do
    dir="$(cd "$(dirname "$src")" 2>/dev/null && pwd)"
    [ -n "$dir" ] || dir="$PWD"
    src="$(basename "$src")"
    [ -L "$dir/$src" ] || break
    src="$(readlink "$dir/$src")"
    [[ "$src" == /* ]] || src="$dir/$src"
  done
  echo "$dir/$src"
}

date_iso_seconds() {
  if date -Iseconds >/dev/null 2>&1; then
    date -Iseconds
  else
    date "+%Y-%m-%dT%H:%M:%S%z"
  fi
}

detect_os_id() {
  if [ -f /etc/os-release ]; then
    # shellcheck source=/dev/null
    . /etc/os-release
    echo "${ID:-unknown}"
  else
    echo "unknown"
  fi
}

detect_os_id_like() {
  if [ -f /etc/os-release ]; then
    # shellcheck source=/dev/null
    . /etc/os-release
    echo "${ID_LIKE:-$ID}"
  else
    echo "unknown"
  fi
}

# FIX (1.7.0): escape a string for safe embedding inside a BRE/ERE grep
# pattern. Package names can legally contain '.', '+', '[' etc (e.g.
# "gcc-12", "libssl1.1"); without this, grep patterns built from raw
# package names can match more (or less) than intended, or error out.
regex_escape() {
  printf '%s' "$1" | sed -e 's/[][\\.^$*+?(){}|]/\\&/g'
}

