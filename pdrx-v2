#!/usr/bin/env bash
#
# pdrx - Portable Dynamic Reproducible gnu/linuX
# Version 2.0 Testing Branch
#
# This is the v2.0 testing branch that adds:
# - Enhanced sync with auto-discovery
# - GNOME extensions tracking
# - Flatpak remote tracking  
# - APT repository capture
# - New YAML config format (v2.0)
#
# Usage: pdrx v2 [discover|sync|apply|doctor]

set -euo pipefail

PDRX_VERSION="2.0.0-testing"
PDRX_HOME="${PDRX_HOME:-$HOME/.pdrx}"
PDRX_V2_DIR="$PDRX_HOME/v2"
PDRX_V2_CONFIG="$PDRX_V2_DIR/config"
PDRX_V2_PLUGINS="$PDRX_V2_DIR/plugins"
PDRX_V2_PROFILES="$PDRX_V2_DIR/profiles"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

log_info() {
  echo -e "${BLUE}[INFO]${NC} $1"
}

log_success() {
  echo -e "${GREEN}[SUCCESS]${NC} $1"
}

log_warn() {
  echo -e "${YELLOW}[WARN]${NC} $1"
}

log_error() {
  echo -e "${RED}[ERROR]${NC} $1"
}

# =============================================================================
# V2.0 DISCOVERY COMMANDS
# =============================================================================

cmd_v2_discover() {
  local target="${1:-all}"
  local output="${2:-}"
  
  log_info "PDRX v2.0 Discovery: $target"
  
  case "$target" in
    gnome|extensions)
      discover_gnome_extensions "$output"
      ;;
    flatpak)
      discover_flatpak "$output"
      ;;
    apt|repos)
      discover_apt_repos "$output"
      ;;
    services)
      discover_systemd_services "$output"
      ;;
    all|full)
      discover_all "$output"
      ;;
    *)
      log_error "Unknown discovery target: $target"
      log_info "Available targets: gnome, flatpak, apt, services, all"
      return 1
      ;;
  esac
}

discover_gnome_extensions() {
  local output="${1:-}"
  
  log_info "Discovering GNOME Shell extensions..."
  
  # Check if running in GNOME
  if ! is_gnome_session; then
    log_warn "Not running in GNOME session"
    return 1
  fi
  
  # Use Python prototype if available
  local prototype="$PDRX_V2_PLUGINS/gnome_extensions.py"
  if [[ -f "$prototype" ]]; then
    if [[ -n "$output" ]]; then
      python3 "$prototype" discover -o "$output" -f yaml
    else
      python3 "$prototype" discover -f yaml
    fi
    return 0
  fi
  
  # Fallback to bash implementation
  _discover_gnome_extensions_bash "$output"
}

_discover_gnome_extensions_bash() {
  local output="${1:-}"
  
  local shell_version
  shell_version=$(gnome-shell --version 2>/dev/null | grep -oP '\d+\.\d+' | head -1 || echo "unknown")
  
  log_info "GNOME Shell version: $shell_version"
  
  # Get enabled extensions
  local enabled_exts
  enabled_exts=$(gsettings get org.gnome.shell enabled-extensions 2>/dev/null || echo "[]")
  
  log_info "Enabled extensions: $enabled_exts"
  
  # Parse extensions and gather info
  local yaml_output="pdrx:
  version: \"2.0\"
  generated_at: \"$(date -Iseconds)\"
  gnome_shell_version: \"$shell_version\"

desktop:
  environment: gnome
  gnome:
    extensions:"
  
  # Process each extension
  local ext_uuid
  for ext_uuid in $(echo "$enabled_exts" | tr "[]'," " "); do
    [[ -z "$ext_uuid" ]] && continue
    
    local ext_name="${ext_uuid%%@*}"
    local ext_path="$HOME/.local/share/gnome-shell/extensions/$ext_uuid"
    local source="user"
    
    if [[ ! -d "$ext_path" ]]; then
      ext_path="/usr/share/gnome-shell/extensions/$ext_uuid"
      source="system"
    fi
    
    if [[ -f "$ext_path/metadata.json" ]]; then
      local version
      version=$(jq -r '.version // "unknown"' "$ext_path/metadata.json" 2>/dev/null || echo "unknown")
      yaml_output+="
      - uuid: \"$ext_uuid\"
        name: \"$ext_name\"
        version: \"$version\"
        source: \"$source\""
    else
      yaml_output+="
      - uuid: \"$ext_uuid\"
        name: \"$ext_name\"
        version: \"unknown\"
        source: \"$source\""
    fi
  done
  
  if [[ -n "$output" ]]; then
    echo "$yaml_output" > "$output"
    log_success "Extensions saved to: $output"
  else
    echo "$yaml_output"
  fi
}

discover_flatpak() {
  local output="${1:-}"
  
  log_info "Discovering Flatpak configuration..."
  
  if ! command -v flatpak >/dev/null 2>&1; then
    log_warn "Flatpak not installed"
    return 1
  fi
  
  local yaml_output="flatpak:
  remotes:"
  
  # Discover remotes
  while IFS=$'\t' read -r name url options; do
    [[ -z "$name" ]] && continue
    yaml_output+="
    - name: \"$name\"
      url: \"$url\""
    if [[ "$options" == *"user"* ]]; then
      yaml_output+="
      type: user"
    else
      yaml_output+="
      type: system"
    fi
  done <<< "$(flatpak remotes --columns=name,url,options 2>/dev/null || true)"
  
  # Discover apps
  yaml_output+="
  apps:"
  
  while IFS=$'\t' read -r app_id origin install version; do
    [[ -z "$app_id" ]] && continue
    yaml_output+="
    - id: \"$app_id\"
      remote: \"$origin\""
    [[ -n "$version" && "$version" != "-" ]] && yaml_output+="
      version: \"$version\""
    [[ "$install" == "user" ]] && yaml_output+="
      installation: user"
  done <<< "$(flatpak list --app --columns=application,origin,installation,version 2>/dev/null || true)"
  
  if [[ -n "$output" ]]; then
    echo "$yaml_output" > "$output"
    log_success "Flatpak config saved to: $output"
  else
    echo "$yaml_output"
  fi
}

discover_apt_repos() {
  local output="${1:-}"
  
  log_info "Discovering APT repositories..."
  
  if [[ ! -f /etc/os-release ]]; then
    log_warn "Not a Debian-based system"
    return 1
  fi
  
  local yaml_output="apt:
  repos:"
  
  # Parse sources.list.d files
  for list_file in /etc/apt/sources.list.d/*.list; do
    [[ -f "$list_file" ]] || continue
    
    local filename
    filename=$(basename "$list_file")
    
    # Skip standard repos
    [[ "$filename" == "debian.list" ]] && continue
    [[ "$filename" == "debian.sources" ]] && continue
    
    yaml_output+="
    # From $filename"
    
    while read -r line; do
      # Skip comments and empty lines
      [[ "$line" =~ ^\s*# ]] && continue
      [[ -z "$line" ]] && continue
      
      # Parse deb line
      if [[ "$line" =~ ^deb\s+\[.*\]\s+(.+)\s+(.+)\s+(.+)$ ]]; then
        local uri="${BASH_REMATCH[1]}"
        local suite="${BASH_REMATCH[2]}"
        local components="${BASH_REMATCH[3]}"
        
        yaml_output+="
    ${filename%.list}:
      uris: [\"$uri\"]
      suites: [\"$suite\"]
      components: [$components]"
      fi
    done < "$list_file"
  done
  
  # Check for .sources files (deb822 format)
  for sources_file in /etc/apt/sources.list.d/*.sources; do
    [[ -f "$sources_file" ]] || continue
    yaml_output+="
    # From $sources_file (deb822 format)"
  done
  
  if [[ -n "$output" ]]; then
    echo "$yaml_output" > "$output"
    log_success "APT repos saved to: $output"
  else
    echo "$yaml_output"
  fi
}

discover_systemd_services() {
  local output="${1:-}"
  
  log_info "Discovering systemd services..."
  
  if ! command -v systemctl >/dev/null 2>&1; then
    log_warn "systemd not available"
    return 1
  fi
  
  local yaml_output="services:
  enabled:"
  
  # Get enabled services (filtering out auto-enabled system services)
  while read -r service _; do
    [[ -z "$service" ]] && continue
    service="${service%.service}"
    
    # Skip common auto-enabled services
    [[ "$service" == "apparmor" ]] && continue
    [[ "$service" == "cron" ]] && continue
    [[ "$service" == "dbus" ]] && continue
    [[ "$service" == "networking" ]] && continue
    [[ "$service" == "rsyslog" ]] && continue
    [[ "$service" == "systemd-timesyncd" ]] && continue
    [[ "$service" == "unattended-upgrades" ]] && continue
    
    yaml_output+="
    - $service"
  done <<< "$(systemctl list-unit-files --state=enabled --type=service --no-legend --quiet 2>/dev/null | awk '{print $1}' || true)"
  
  if [[ -n "$output" ]]; then
    echo "$yaml_output" > "$output"
    log_success "Services saved to: $output"
  else
    echo "$yaml_output"
  fi
}

discover_all() {
  local output="${1:-$PDRX_V2_CONFIG/full-discovery.yaml}"
  
  log_info "Running full system discovery..."
  
  mkdir -p "$PDRX_V2_CONFIG"
  
  # Create combined discovery
  local timestamp
  timestamp=$(date -Iseconds)
  
  cat > "$output" << EOF
pdrx:
  version: "2.0"
  generated_at: "$timestamp"
  profile: "discovered"

EOF
  
  # Add each discovery section
  log_info "  → Discovering packages..."
  echo "# Legacy packages.conf format" >> "$output"
  echo "# Import with: pdrx v2 import-packages" >> "$output"
  
  log_info "  → Discovering GNOME extensions..."
  {
    echo ""
    echo "desktop:"
    echo "  environment: gnome"
    echo "  gnome:"
    echo "    extensions:"
  } >> "$output"
  
  # Add extensions if in GNOME
  if is_gnome_session; then
    local exts
    exts=$(gsettings get org.gnome.shell enabled-extensions 2>/dev/null || echo "[]")
    for ext in $(echo "$exts" | tr "[]'," " "); do
      [[ -n "$ext" ]] && echo "      - uuid: \"$ext\"" >> "$output"
    done
  fi
  
  log_info "  → Discovering Flatpak..."
  if command -v flatpak >/dev/null 2>&1; then
    {
      echo ""
      discover_flatpak
    } >> "$output" 2>/dev/null || true
  fi
  
  log_info "  → Discovering APT repos..."
  if [[ -f /etc/os-release ]]; then
    {
      echo ""
      discover_apt_repos
    } >> "$output" 2>/dev/null || true
  fi
  
  log_info "  → Discovering services..."
  {
    echo ""
    discover_systemd_services
  } >> "$output" 2>/dev/null || true
  
  log_success "Full discovery saved to: $output"
  log_info "Review and edit before applying: pdrx v2 apply --config $output"
}

# =============================================================================
# V2.0 UTILITY FUNCTIONS
# =============================================================================

is_gnome_session() {
  local desktop_session
  desktop_session="${DESKTOP_SESSION:-}${XDG_CURRENT_DESKTOP:-}"
  [[ "$desktop_session" == *"gnome"* ]]
}

# =============================================================================
# V2.0 DOCTOR COMMAND
# =============================================================================

cmd_v2_doctor() {
  log_info "PDRX v2.0 Health Check"
  echo ""
  
  local issues=0
  
  # Check v2 directories exist
  if [[ ! -d "$PDRX_V2_DIR" ]]; then
    log_warn "v2.0 directory not initialized"
    log_info "Run: mkdir -p $PDRX_V2_DIR/{config,plugins,profiles}"
    ((issues++))
  else
    log_success "v2.0 directory exists"
  fi
  
  # Check for Python prototype
  if [[ -f "$PDRX_V2_PLUGINS/gnome_extensions.py" ]]; then
    log_success "GNOME extensions plugin available"
  else
    log_warn "GNOME extensions plugin not found"
    log_info "Copy prototypes/gnome_extensions.py to $PDRX_V2_PLUGINS/"
    ((issues++))
  fi
  
  # Check GNOME session
  if is_gnome_session; then
    log_success "Running in GNOME session"
    
    local shell_version
    shell_version=$(gnome-shell --version 2>/dev/null | grep -oP '\d+\.\d+' | head -1 || echo "unknown")
    log_info "  GNOME Shell version: $shell_version"
    
    local ext_count
    ext_count=$(gsettings get org.gnome.shell enabled-extensions 2>/dev/null | tr ',' '\n' | wc -l)
    log_info "  Enabled extensions: $ext_count"
  else
    log_warn "Not in GNOME session (GNOME discovery will be limited)"
  fi
  
  # Check package managers
  echo ""
  log_info "Package managers:"
  for pm in apt dnf pacman flatpak snap cargo; do
    if command -v "$pm" >/dev/null 2>&1; then
      log_success "  ✓ $pm"
    else
      echo "    - $pm (not installed)"
    fi
  done
  
  # Check Python availability
  echo ""
  if command -v python3 >/dev/null 2>&1; then
    log_success "Python3 available: $(python3 --version)"
  else
    log_warn "Python3 not found (v2.0 features require Python)"
    ((issues++))
  fi
  
  # Check YAML libraries
  if python3 -c "import yaml" 2>/dev/null; then
    log_success "PyYAML available"
  else
    log_warn "PyYAML not installed (pip install pyyaml)"
    ((issues++))
  fi
  
  echo ""
  if [[ $issues -eq 0 ]]; then
    log_success "Health check passed! Ready for v2.0 testing."
    return 0
  else
    log_warn "Health check found $issues issue(s). See above."
    return 1
  fi
}

# =============================================================================
# V2.0 MAIN COMMAND
# =============================================================================

cmd_v2() {
  local subcmd="${1:-help}"
  shift || true
  
  case "$subcmd" in
    discover|disc)
      cmd_v2_discover "$@"
      ;;
    doctor)
      cmd_v2_doctor
      ;;
    help|--help|-h)
      echo "PDRX v2.0 Testing Commands:"
      echo ""
      echo "  pdrx v2 discover [TARGET] [OUTPUT]  - Discover system state"
      echo "    Targets: gnome, flatpak, apt, services, all"
      echo "    Example: pdrx v2 discover gnome -o extensions.yaml"
      echo ""
      echo "  pdrx v2 doctor                      - Health check v2.0 setup"
      echo ""
      echo "  pdrx v2 help                        - Show this help"
      echo ""
      echo "For legacy commands, use: pdrx [sync|apply|backup|...]"
      ;;
    *)
      log_error "Unknown v2 command: $subcmd"
      log_info "Run 'pdrx v2 help' for available commands"
      return 1
      ;;
  esac
}

# =============================================================================
# MAIN ENTRY POINT
# =============================================================================

# If called directly, show help
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
  echo "PDRX v2.0 Testing Module"
  echo ""
  echo "This module is sourced by the main pdrx script."
  echo "Run: pdrx v2 [command]"
fi
